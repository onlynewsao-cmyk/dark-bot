# ╔══════════════════════════════════════════════════════════╗
# ║           DARK BOT — .env.example                       ║
# ║  Copie para .env e preencha. NUNCA commite o .env real. ║
# ╚══════════════════════════════════════════════════════════╝

# ── Ambiente ─────────────────────────────────────────────────
NODE_ENV=production
PORT=10000

# URL do serviço no Render (ou localhost:3000 em dev)
APP_URL=https://SEU-NOME.onrender.com

# ── Bot ──────────────────────────────────────────────────────
BOT_NAME=DARK BOT
BOT_NUMBER=244XXXXXXXXX
BOT_PREFIX=!

# ── Dono ─────────────────────────────────────────────────────
OWNER_NAME=Dark Net
OWNER_NUMBER=244XXXXXXXXX
OWNER_USERNAME=darknet
OWNER_PASSWORD=SenhaSegura123!

# ── Sessão (string aleatória longa, mín 32 caracteres) ───────
SESSION_SECRET=mude-isso-para-uma-string-aleatoria-longa

# ── MongoDB Atlas ─────────────────────────────────────────────
# Crie em mongodb.com (gratuito) → Connect → Drivers
# Formato: mongodb+srv://USUARIO:SENHA@cluster.mongodb.net/darkbot
MONGODB_URI=mongodb+srv://usuario:senha@cluster.mongodb.net/darkbot?retryWrites=true&w=majority

# ── Cloudinary (hospedagem de mídia) ─────────────────────────
# Crie em cloudinary.com (gratuito)
CLOUDINARY_CLOUD_NAME=seu_cloud_name
CLOUDINARY_API_KEY=sua_api_key
CLOUDINARY_API_SECRET=seu_api_secret

# ── IA (tudo opcional — pelo menos 1 ativa o assistente) ─────
# Groq: groq.com → gratuito e rápido
GROQ_API_KEY=gsk_xxxxx

# Google Gemini: aistudio.google.com → gratuito
GEMINI_API_KEY=AIzaSyxxxxx

# ── YouTube / Downloads ───────────────────────────────────────
YTDLP_EXTRACTOR_ARGS=youtube:player_client=default,web_creator,android_vr
# YTDLP_COOKIES_BASE64=   (opcional: cookies do YouTube em base64)
MAX_YOUTUBE_SECONDS=3600
STICKER_VIDEO_MAX_SEC=8

# ── Tenor GIFs ────────────────────────────────────────────────
# tenor.com → obter API key gratuita
TENOR_API_KEY=sua_tenor_key

# ── Facebook Publisher (opcional) ────────────────────────────
# FB_PAGE_ID=
# FB_PAGE_ACCESS_TOKEN=
# FB_GRAPH_VERSION=v20.0

# ── Node.js ───────────────────────────────────────────────────
NODE_OPTIONS=--max-old-space-size=400

# Canal WhatsApp (aparece no menu)
WHATSAPP_CHANNEL_URL=https://whatsapp.com/channel/0029VbC8voN4Y9lszc9VuT2D
