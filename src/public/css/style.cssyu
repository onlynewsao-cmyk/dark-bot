/* ============================================
   DARK BOT — CYBERPUNK NEON DASHBOARD v3.0
   Redesigned for speed, clarity & UX
   ============================================ */
@import url('https://fonts.googleapis.com/css2?family=Orbitron:wght@400;600;700;900&family=Rajdhani:wght@400;500;600;700&family=JetBrains+Mono:wght@400;700&display=swap');

* { margin: 0; padding: 0; box-sizing: border-box; }
:root {
  --bg-0: #04040c;
  --bg-1: #08081a;
  --bg-2: #0f0f22;
  --bg-3: #171730;
  --bg-card: rgba(15, 15, 34, 0.75);
  --neon-purple: #b14aed;
  --neon-cyan: #00f0ff;
  --neon-pink: #ff2e88;
  --neon-green: #00ff9d;
  --neon-yellow: #ffd700;
  --neon-red: #ff3860;
  --neon-orange: #ff7c2a;
  --text: #e8e8ff;
  --text-muted: #6a6a8e;
  --border: rgba(177, 74, 237, 0.2);
  --border-hover: rgba(0, 240, 255, 0.5);
  --gradient-1: linear-gradient(135deg, #b14aed 0%, #00f0ff 100%);
  --gradient-2: linear-gradient(135deg, #ff2e88 0%, #b14aed 100%);
  --gradient-3: linear-gradient(135deg, #00f0ff 0%, #00ff9d 100%);
  --gradient-gold: linear-gradient(135deg, #ffd700 0%, #ff8c00 100%);
  --gradient-danger: linear-gradient(135deg, #ff3860 0%, #ff7c2a 100%);
  --shadow-neon: 0 0 20px rgba(177, 74, 237, 0.4);
  --shadow-cyan: 0 0 20px rgba(0, 240, 255, 0.4);
  --radius: 14px;
  --sidebar-w: 270px;
  --transition: 0.25s ease;
}

html, body { height: 100%; }
body {
  font-family: 'Rajdhani', -apple-system, BlinkMacSystemFont, sans-serif;
  background: var(--bg-0);
  color: var(--text);
  line-height: 1.5;
  overflow-x: hidden;
  min-height: 100vh;
  font-weight: 500;
}

/* ===== ANIMATED BACKGROUND ===== */
body::before {
  content: '';
  position: fixed;
  inset: 0;
  z-index: -2;
  background:
    radial-gradient(ellipse at 10% 20%, rgba(177, 74, 237, 0.15) 0%, transparent 50%),
    radial-gradient(ellipse at 90% 80%, rgba(0, 240, 255, 0.12) 0%, transparent 50%),
    radial-gradient(ellipse at 50% 50%, rgba(255, 46, 136, 0.06) 0%, transparent 60%);
  animation: bgPulse 18s ease infinite;
}
body::after {
  content: '';
  position: fixed;
  inset: 0;
  z-index: -1;
  background-image:
    linear-gradient(rgba(177, 74, 237, 0.03) 1px, transparent 1px),
    linear-gradient(90deg, rgba(0, 240, 255, 0.03) 1px, transparent 1px);
  background-size: 60px 60px;
  pointer-events: none;
}
@keyframes bgPulse {
  0%, 100% { opacity: 1; }
  50% { opacity: 0.6; }
}

a { color: var(--neon-cyan); text-decoration: none; transition: all var(--transition); }
a:hover { color: var(--neon-pink); text-shadow: 0 0 8px currentColor; }

code, pre {
  font-family: 'JetBrains Mono', monospace;
  background: var(--bg-2);
  padding: 2px 7px;
  border-radius: 5px;
  color: var(--neon-cyan);
  border: 1px solid var(--border);
  font-size: 0.85em;
}

::selection { background: rgba(177, 74, 237, 0.5); color: white; }

/* ===== SCROLLBAR ===== */
::-webkit-scrollbar { width: 6px; height: 6px; }
::-webkit-scrollbar-track { background: var(--bg-1); }
::-webkit-scrollbar-thumb { background: var(--gradient-1); border-radius: 3px; }

/* ============================================
   BUTTONS
   ============================================ */
.btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 0.5rem;
  padding: 0.6rem 1.4rem;
  border-radius: 10px;
  font-size: 0.9rem;
  font-weight: 700;
  font-family: 'Rajdhani', sans-serif;
  cursor: pointer;
  border: 1px solid transparent;
  transition: all var(--transition);
  letter-spacing: 0.5px;
  white-space: nowrap;
  position: relative;
  overflow: hidden;
}
.btn:hover { transform: translateY(-2px); }
.btn:active { transform: translateY(0); }
.btn-primary {
  background: var(--gradient-1);
  color: white;
  border-color: transparent;
  box-shadow: 0 4px 20px rgba(177, 74, 237, 0.4);
}
.btn-primary:hover { box-shadow: 0 6px 30px rgba(177, 74, 237, 0.6); color: white; }
.btn-success {
  background: transparent;
  color: var(--neon-green);
  border-color: var(--neon-green);
  box-shadow: 0 0 12px rgba(0, 255, 157, 0.2);
}
.btn-success:hover { background: rgba(0, 255, 157, 0.12); color: var(--neon-green); box-shadow: 0 0 20px rgba(0, 255, 157, 0.4); }
.btn-danger {
  background: transparent;
  color: var(--neon-red);
  border-color: var(--neon-red);
  box-shadow: 0 0 12px rgba(255, 56, 96, 0.2);
}
.btn-danger:hover { background: rgba(255, 56, 96, 0.12); color: var(--neon-red); }
.btn-warning {
  background: transparent;
  color: var(--neon-yellow);
  border-color: var(--neon-yellow);
}
.btn-warning:hover { background: rgba(255, 215, 0, 0.12); color: var(--neon-yellow); }
.btn-ghost {
  background: transparent;
  color: var(--text-muted);
  border-color: var(--border);
}
.btn-ghost:hover { border-color: var(--neon-cyan); color: var(--neon-cyan); }
.btn-sm { padding: 0.4rem 0.9rem; font-size: 0.82rem; border-radius: 8px; }
.btn-block { width: 100%; }
.btn-icon { padding: 0.5rem; width: 36px; height: 36px; border-radius: 8px; }
.button-row { display: flex; gap: 0.6rem; flex-wrap: wrap; align-items: center; }

/* ============================================
   FORMS
   ============================================ */
.form-group { display: flex; flex-direction: column; gap: 0.4rem; margin-bottom: 1rem; }
.form-group label {
  font-size: 0.82rem;
  font-weight: 700;
  color: var(--text-muted);
  text-transform: uppercase;
  letter-spacing: 1px;
}
.form-group input, .form-group textarea, .form-group select {
  background: var(--bg-1);
  border: 1px solid var(--border);
  border-radius: 10px;
  color: var(--text);
  padding: 0.7rem 1rem;
  font-size: 0.95rem;
  font-family: 'Rajdhani', sans-serif;
  font-weight: 500;
  width: 100%;
  transition: all var(--transition);
}
.form-group input:focus, .form-group textarea:focus, .form-group select:focus {
  outline: none;
  border-color: var(--neon-purple);
  box-shadow: 0 0 0 3px rgba(177, 74, 237, 0.15);
}
.form-group input:disabled { opacity: 0.5; cursor: not-allowed; }
.form-group textarea { resize: vertical; min-height: 90px; }
.form-group select { appearance: none; cursor: pointer; }
.form-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap: 1rem; }
.form-check { flex-direction: row; align-items: center; gap: 0.6rem; }
.form-check input[type="checkbox"] { width: 18px; height: 18px; accent-color: var(--neon-purple); }
small.muted { font-size: 0.78rem; color: var(--text-muted); }

/* ============================================
   CARDS
   ============================================ */
.card {
  background: var(--bg-card);
  backdrop-filter: blur(16px);
  border: 1px solid var(--border);
  border-radius: var(--radius);
  padding: 1.5rem;
  margin-bottom: 1.25rem;
  transition: border-color var(--transition);
  position: relative;
  overflow: hidden;
}
.card::before {
  content: '';
  position: absolute;
  top: 0; left: 0; right: 0;
  height: 2px;
  background: var(--gradient-1);
  opacity: 0;
  transition: opacity var(--transition);
}
.card:hover { border-color: rgba(177, 74, 237, 0.35); }
.card:hover::before { opacity: 1; }
.card h2 {
  font-family: 'Orbitron', sans-serif;
  font-size: 1rem;
  font-weight: 700;
  letter-spacing: 1px;
  margin-bottom: 1.1rem;
  background: var(--gradient-1);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}
.card-neon-cyan { border-color: rgba(0, 240, 255, 0.3); }
.card-neon-green { border-color: rgba(0, 255, 157, 0.3); }
.card-neon-red { border-color: rgba(255, 56, 96, 0.3); }
.card-neon-gold { border-color: rgba(255, 215, 0, 0.3); }

/* ============================================
   AUTH PAGES
   ============================================ */
.auth-wrapper {
  min-height: 100vh;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 1.5rem;
  position: relative;
  overflow: hidden;
}
.auth-wrapper::before {
  content: '';
  position: absolute;
  width: 700px; height: 700px;
  background: var(--gradient-1);
  border-radius: 50%;
  filter: blur(140px);
  opacity: 0.2;
  animation: floatA 10s ease-in-out infinite;
  z-index: -1;
  top: -200px; left: -200px;
}
.auth-wrapper::after {
  content: '';
  position: absolute;
  width: 500px; height: 500px;
  right: -150px; bottom: -150px;
  background: var(--gradient-2);
  border-radius: 50%;
  filter: blur(130px);
  opacity: 0.15;
  animation: floatA 12s ease-in-out infinite reverse;
  z-index: -1;
}
@keyframes floatA {
  0%, 100% { transform: translate(0, 0) scale(1); }
  50% { transform: translate(30px, 40px) scale(1.05); }
}

.auth-card {
  background: rgba(10, 10, 25, 0.88);
  backdrop-filter: blur(40px) saturate(180%);
  border: 1px solid rgba(177, 74, 237, 0.3);
  border-radius: 24px;
  padding: 3rem 2.5rem;
  width: 100%;
  max-width: 440px;
  box-shadow:
    0 30px 80px rgba(0, 0, 0, 0.7),
    inset 0 1px 0 rgba(255, 255, 255, 0.05),
    0 0 0 1px rgba(0, 240, 255, 0.05);
}

.auth-logo {
  text-align: center;
  margin-bottom: 0.75rem;
  animation: logoPulse 3s ease-in-out infinite;
}
.auth-logo img {
  width: 90px; height: 90px;
  border-radius: 50%;
  object-fit: cover;
  box-shadow: 0 0 40px rgba(177, 74, 237, 0.7), 0 0 80px rgba(0, 240, 255, 0.3);
}
@keyframes logoPulse {
  0%, 100% { filter: drop-shadow(0 0 15px rgba(177, 74, 237, 0.6)); }
  50% { filter: drop-shadow(0 0 25px rgba(0, 240, 255, 0.7)); }
}

.auth-title {
  font-family: 'Orbitron', sans-serif;
  text-align: center;
  font-size: 1.9rem;
  font-weight: 900;
  letter-spacing: 3px;
  background: var(--gradient-1);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  margin-bottom: 0.35rem;
  text-transform: uppercase;
}
.auth-subtitle {
  text-align: center;
  color: var(--text-muted);
  margin-bottom: 2rem;
  font-size: 0.82rem;
  letter-spacing: 2px;
  text-transform: uppercase;
}

.auth-form { display: flex; flex-direction: column; gap: 1.1rem; }

.auth-divider {
  text-align: center;
  margin: 1.5rem 0;
  position: relative;
  color: var(--text-muted);
  font-size: 0.78rem;
  letter-spacing: 2px;
  text-transform: uppercase;
}
.auth-divider::before, .auth-divider::after {
  content: '';
  position: absolute;
  top: 50%;
  width: 38%;
  height: 1px;
  background: linear-gradient(90deg, transparent, var(--border), transparent);
}
.auth-divider::before { left: 0; }
.auth-divider::after { right: 0; }

.auth-footer {
  display: flex;
  gap: 0.5rem;
  justify-content: center;
  margin-top: 1.5rem;
  font-size: 0.88rem;
  color: var(--text-muted);
}

/* ============================================
   APP SHELL & SIDEBAR
   ============================================ */
.app-shell { display: flex; min-height: 100vh; }

.sidebar {
  width: var(--sidebar-w);
  min-width: var(--sidebar-w);
  background: rgba(6, 6, 18, 0.92);
  backdrop-filter: blur(24px);
  border-right: 1px solid var(--border);
  display: flex;
  flex-direction: column;
  padding: 1.25rem 0.85rem;
  position: sticky;
  top: 0;
  height: 100vh;
  z-index: 30;
  overflow: hidden;
}

.sidebar-brand {
  display: flex;
  align-items: center;
  gap: 0.75rem;
  padding: 0.25rem 0.5rem 1.25rem;
  border-bottom: 1px solid var(--border);
  margin-bottom: 1rem;
}
.brand-logo {
  width: 46px; height: 46px;
  border-radius: 12px;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 0 20px rgba(177, 74, 237, 0.5);
  animation: logoPulse 3s ease-in-out infinite;
  overflow: hidden;
  flex-shrink: 0;
}
.brand-name {
  font-family: 'Orbitron', sans-serif;
  font-weight: 900;
  font-size: 1rem;
  letter-spacing: 2px;
  background: var(--gradient-1);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  line-height: 1.2;
}
.brand-owner {
  font-size: 0.68rem;
  color: var(--text-muted);
  letter-spacing: 1px;
  text-transform: uppercase;
}

.sidebar-section {
  font-size: 0.65rem;
  color: var(--text-muted);
  padding: 0.6rem 0.75rem 0.25rem;
  margin-top: 0.5rem;
  letter-spacing: 2px;
  text-transform: uppercase;
  font-weight: 700;
  font-family: 'Orbitron', sans-serif;
}

.sidebar-nav {
  display: flex;
  flex-direction: column;
  gap: 0.15rem;
  flex: 1;
  overflow-y: auto;
  scrollbar-width: thin;
}
.sidebar-nav a {
  display: flex;
  align-items: center;
  gap: 0.75rem;
  padding: 0.65rem 0.85rem;
  border-radius: 10px;
  color: var(--text-muted);
  font-weight: 600;
  font-size: 0.9rem;
  transition: all var(--transition);
  border: 1px solid transparent;
  position: relative;
}
.sidebar-nav a:hover {
  background: rgba(177, 74, 237, 0.1);
  border-color: rgba(177, 74, 237, 0.2);
  color: var(--text);
  text-shadow: none;
  transform: translateX(3px);
}
.sidebar-nav a.active {
  background: linear-gradient(135deg, rgba(177, 74, 237, 0.25), rgba(0, 240, 255, 0.15));
  color: white;
  border-color: rgba(177, 74, 237, 0.4);
  box-shadow: 0 2px 15px rgba(177, 74, 237, 0.25);
}
.sidebar-nav a.active::before {
  content: '';
  position: absolute;
  left: 0; top: 20%; bottom: 20%;
  width: 3px;
  background: var(--gradient-1);
  border-radius: 0 2px 2px 0;
}
.sidebar-nav .icon {
  font-size: 1.1rem;
  width: 22px;
  text-align: center;
  flex-shrink: 0;
}

.sidebar-footer {
  border-top: 1px solid var(--border);
  padding-top: 0.85rem;
  margin-top: auto;
}
.user-card {
  display: flex;
  align-items: center;
  gap: 0.65rem;
  padding: 0.65rem 0.75rem;
  margin-bottom: 0.6rem;
  background: var(--bg-2);
  border-radius: 10px;
  border: 1px solid var(--border);
}
.user-avatar {
  width: 38px; height: 38px;
  border-radius: 50%;
  background: var(--gradient-1);
  display: flex;
  align-items: center;
  justify-content: center;
  font-weight: 900;
  font-size: 1rem;
  color: white;
  font-family: 'Orbitron', sans-serif;
  flex-shrink: 0;
}
.user-name { font-weight: 700; font-size: 0.88rem; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
.user-role {
  font-size: 0.65rem;
  text-transform: uppercase;
  letter-spacing: 1px;
  font-weight: 700;
  font-family: 'Orbitron', sans-serif;
}
.role-owner { color: var(--neon-yellow); }
.role-premium { color: var(--neon-purple); }
.role-free { color: var(--text-muted); }

/* ===== MOBILE MENU ===== */
.menu-toggle {
  display: none;
  position: fixed;
  top: 0.85rem; left: 0.85rem;
  z-index: 60;
  background: var(--gradient-1);
  border: none;
  color: white;
  width: 42px; height: 42px;
  border-radius: 10px;
  font-size: 1.2rem;
  cursor: pointer;
  box-shadow: 0 4px 20px rgba(177, 74, 237, 0.5);
  transition: all var(--transition);
}
.menu-toggle:hover { transform: scale(1.05); }
.sidebar-overlay {
  display: none;
  position: fixed;
  inset: 0;
  background: rgba(0, 0, 0, 0.7);
  z-index: 29;
  backdrop-filter: blur(4px);
}

/* ============================================
   MAIN CONTENT
   ============================================ */
.main {
  flex: 1;
  padding: 2rem 2rem 2rem;
  max-width: calc(100% - var(--sidebar-w));
  min-height: 100vh;
  overflow-x: hidden;
}

.page-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  flex-wrap: wrap;
  gap: 1rem;
  margin-bottom: 1.75rem;
  padding-bottom: 1.25rem;
  border-bottom: 1px solid var(--border);
}
.page-header h1 {
  font-family: 'Orbitron', sans-serif;
  font-size: 1.6rem;
  font-weight: 900;
  letter-spacing: 1px;
  background: var(--gradient-1);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}
.page-header p.muted { color: var(--text-muted); font-size: 0.88rem; margin-top: 0.2rem; }

.bot-status {
  display: flex;
  align-items: center;
  gap: 0.5rem;
  padding: 0.5rem 1rem;
  background: var(--bg-2);
  border: 1px solid var(--border);
  border-radius: 999px;
  font-size: 0.85rem;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 1px;
}
.status-dot {
  width: 10px; height: 10px;
  border-radius: 50%;
  flex-shrink: 0;
}
.status-connected { background: var(--neon-green); box-shadow: 0 0 10px var(--neon-green), 0 0 20px rgba(0,255,157,0.4); animation: pulse 2s infinite; }
.status-connecting { background: var(--neon-yellow); box-shadow: 0 0 10px var(--neon-yellow); animation: pulse 1s infinite; }
.status-disconnected { background: var(--neon-red); box-shadow: 0 0 10px var(--neon-red); }
.status-qr, .status-pairing { background: var(--neon-cyan); box-shadow: 0 0 10px var(--neon-cyan); animation: pulse 1.5s infinite; }
@keyframes pulse {
  0%, 100% { transform: scale(1); opacity: 1; }
  50% { transform: scale(1.3); opacity: 0.7; }
}

/* ============================================
   STAT CARDS
   ============================================ */
.stats-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(165px, 1fr));
  gap: 1rem;
  margin-bottom: 1.5rem;
}
.stat-card {
  background: var(--bg-card);
  backdrop-filter: blur(16px);
  border: 1px solid var(--border);
  border-radius: var(--radius);
  padding: 1.25rem 1rem;
  display: flex;
  align-items: center;
  gap: 1rem;
  transition: all var(--transition);
  cursor: default;
  position: relative;
  overflow: hidden;
}
.stat-card::after {
  content: '';
  position: absolute;
  bottom: 0; left: 0; right: 0;
  height: 2px;
  opacity: 0;
  transition: opacity var(--transition);
}
.stat-card:hover {
  border-color: rgba(0, 240, 255, 0.35);
  transform: translateY(-3px);
  box-shadow: 0 8px 30px rgba(0, 240, 255, 0.1);
}
.stat-card:hover::after { opacity: 1; background: var(--gradient-3); }
.stat-icon {
  font-size: 2rem;
  width: 52px; height: 52px;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 12px;
  background: rgba(177, 74, 237, 0.12);
  border: 1px solid rgba(177, 74, 237, 0.2);
  flex-shrink: 0;
}
.stat-info { flex: 1; min-width: 0; }
.stat-label {
  font-size: 0.72rem;
  color: var(--text-muted);
  text-transform: uppercase;
  letter-spacing: 1.5px;
  font-weight: 700;
}
.stat-value {
  font-family: 'Orbitron', sans-serif;
  font-size: 1.6rem;
  font-weight: 900;
  background: var(--gradient-1);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  line-height: 1.1;
  margin-top: 0.2rem;
}
.stat-change {
  font-size: 0.72rem;
  color: var(--neon-green);
  font-weight: 700;
  margin-top: 0.2rem;
}

/* ============================================
   QUICK CARDS GRID
   ============================================ */
.quick-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
  gap: 1rem;
}
.quick-card {
  display: flex;
  align-items: center;
  gap: 1rem;
  padding: 1rem 1.1rem;
  background: var(--bg-1);
  border: 1px solid var(--border);
  border-radius: 12px;
  color: var(--text);
  transition: all var(--transition);
}
.quick-card:hover {
  border-color: var(--neon-cyan);
  background: rgba(0, 240, 255, 0.05);
  transform: translateY(-2px);
  box-shadow: 0 6px 20px rgba(0, 240, 255, 0.15);
  color: var(--text);
  text-shadow: none;
}
.quick-icon { font-size: 1.8rem; flex-shrink: 0; }
.quick-card strong { font-size: 0.92rem; font-weight: 700; display: block; }
.quick-card p { font-size: 0.78rem; color: var(--text-muted); margin: 0; }

/* ============================================
   TOGGLE SWITCHES
   ============================================ */
.toggles-grid { display: grid; gap: 0.7rem; }
.toggle-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 0.85rem 1rem;
  background: var(--bg-1);
  border: 1px solid var(--border);
  border-radius: 10px;
  gap: 1rem;
  transition: border-color var(--transition);
}
.toggle-row:hover { border-color: rgba(177, 74, 237, 0.3); }
.toggle-info { flex: 1; }
.toggle-info strong { font-size: 0.92rem; display: block; margin-bottom: 0.15rem; }
.toggle-info .muted { font-size: 0.78rem; }

.switch {
  position: relative;
  display: inline-block;
  width: 48px; height: 26px;
  flex-shrink: 0;
}
.switch input { opacity: 0; width: 0; height: 0; }
.slider {
  position: absolute;
  cursor: pointer;
  top: 0; left: 0; right: 0; bottom: 0;
  background: var(--bg-3);
  border: 1px solid var(--border);
  transition: .3s;
  border-radius: 26px;
}
.slider:before {
  position: absolute;
  content: "";
  height: 18px; width: 18px;
  left: 3px; bottom: 3px;
  background: white;
  transition: .3s;
  border-radius: 50%;
  box-shadow: 0 2px 6px rgba(0,0,0,0.3);
}
.switch input:checked + .slider { background: linear-gradient(135deg, #b14aed, #00f0ff); border-color: transparent; }
.switch input:checked + .slider:before { transform: translateX(22px); }

/* ============================================
   ALERTS
   ============================================ */
.alert {
  padding: 0.9rem 1.1rem;
  border-radius: 10px;
  margin-bottom: 1.1rem;
  font-size: 0.88rem;
  border: 1px solid;
  display: flex;
  align-items: flex-start;
  gap: 0.6rem;
  line-height: 1.5;
}
.alert-error { background: rgba(255, 56, 96, 0.08); color: var(--neon-red); border-color: rgba(255, 56, 96, 0.25); }
.alert-success { background: rgba(0, 255, 157, 0.08); color: var(--neon-green); border-color: rgba(0, 255, 157, 0.25); }
.alert-info { background: rgba(0, 240, 255, 0.08); color: var(--neon-cyan); border-color: rgba(0, 240, 255, 0.25); }
.alert-warning { background: rgba(255, 215, 0, 0.08); color: var(--neon-yellow); border-color: rgba(255, 215, 0, 0.25); }

/* ============================================
   TABLES
   ============================================ */
.table-wrap { overflow-x: auto; border-radius: 10px; }
.table { width: 100%; border-collapse: collapse; font-size: 0.9rem; }
.table th, .table td {
  text-align: left;
  padding: 0.8rem 1rem;
  border-bottom: 1px solid var(--border);
}
.table th {
  color: var(--neon-cyan);
  font-weight: 700;
  font-size: 0.7rem;
  text-transform: uppercase;
  letter-spacing: 2px;
  font-family: 'Orbitron', sans-serif;
  background: rgba(0, 240, 255, 0.03);
}
.table tr { transition: all 0.2s; }
.table tbody tr:last-child td { border-bottom: none; }
.table tbody tr:hover { background: rgba(177, 74, 237, 0.05); }

/* ============================================
   CHIPS / BADGES
   ============================================ */
.chip {
  display: inline-block;
  padding: 3px 10px;
  border-radius: 999px;
  font-size: 0.7rem;
  font-weight: 700;
  background: var(--bg-3);
  color: var(--text-muted);
  text-transform: uppercase;
  letter-spacing: 1px;
  font-family: 'Orbitron', sans-serif;
  border: 1px solid var(--border);
}
.chip-owner { background: rgba(255, 215, 0, 0.12); color: var(--neon-yellow); border-color: rgba(255, 215, 0, 0.4); }
.chip-premium { background: rgba(177, 74, 237, 0.12); color: var(--neon-purple); border-color: rgba(177, 74, 237, 0.4); }
.chip-free { background: rgba(122, 122, 156, 0.12); color: var(--text-muted); border-color: var(--border); }
.chip-success { background: rgba(0, 255, 157, 0.12); color: var(--neon-green); border-color: rgba(0, 255, 157, 0.4); }
.chip-danger { background: rgba(255, 56, 96, 0.12); color: var(--neon-red); border-color: rgba(255, 56, 96, 0.4); }
.chip-info { background: rgba(0, 240, 255, 0.12); color: var(--neon-cyan); border-color: rgba(0, 240, 255, 0.4); }
.chip-muted { background: rgba(122, 122, 156, 0.08); color: var(--text-muted); }
.chip-warn { background: rgba(255, 215, 0, 0.12); color: var(--neon-yellow); border-color: rgba(255, 215, 0, 0.4); }

/* ============================================
   CONNECT PAGE (QR / PAIR)
   ============================================ */
.connect-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 1.25rem;
  margin-bottom: 1.5rem;
}
@media (max-width: 860px) { .connect-grid { grid-template-columns: 1fr; } }

.qr-area, .pair-area {
  min-height: 300px;
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--bg-1);
  border: 1px solid var(--border);
  border-radius: var(--radius);
  margin: 1rem 0;
  padding: 1.5rem;
  position: relative;
  overflow: hidden;
}
.qr-area img {
  max-width: 240px;
  height: auto;
  border-radius: 12px;
  background: white;
  padding: 10px;
  box-shadow: 0 0 40px rgba(0, 240, 255, 0.3);
  animation: qrGlow 2s ease-in-out infinite;
}
@keyframes qrGlow {
  0%, 100% { box-shadow: 0 0 30px rgba(0, 240, 255, 0.3); }
  50% { box-shadow: 0 0 50px rgba(177, 74, 237, 0.5); }
}
.qr-placeholder {
  text-align: center;
  color: var(--text-muted);
}
.qr-placeholder.success { color: var(--neon-green); }
.qr-icon {
  font-size: 3.5rem;
  margin-bottom: 0.5rem;
}

.pair-code {
  font-family: 'JetBrains Mono', monospace;
  font-size: 2.4rem;
  font-weight: 900;
  letter-spacing: 0.3em;
  background: var(--gradient-1);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  text-align: center;
  padding: 1rem;
  animation: codeGlow 2s ease-in-out infinite;
}
@keyframes codeGlow {
  0%, 100% { filter: drop-shadow(0 0 15px rgba(177, 74, 237, 0.5)); }
  50% { filter: drop-shadow(0 0 25px rgba(0, 240, 255, 0.7)); }
}

.spinner {
  width: 45px; height: 45px;
  border: 3px solid var(--bg-3);
  border-top-color: var(--neon-purple);
  border-right-color: var(--neon-cyan);
  border-radius: 50%;
  animation: spin 0.7s linear infinite;
  margin: 0 auto 0.75rem;
}
@keyframes spin { to { transform: rotate(360deg); } }

/* ============================================
   MEDIA GRID
   ============================================ */
.media-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(185px, 1fr));
  gap: 1rem;
}
.media-card {
  background: var(--bg-1);
  border: 1px solid var(--border);
  border-radius: 12px;
  overflow: hidden;
  transition: all var(--transition);
}
.media-card:hover {
  border-color: var(--neon-cyan);
  transform: translateY(-3px);
  box-shadow: 0 10px 30px rgba(0, 240, 255, 0.15);
}
.media-thumb {
  aspect-ratio: 1;
  background: var(--bg-2);
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
}
.media-thumb img, .media-thumb video { width: 100%; height: 100%; object-fit: cover; }
.media-icon { font-size: 2.5rem; }
.media-info { padding: 0.75rem; }
.media-info strong { display: block; font-size: 0.82rem; word-break: break-word; margin-bottom: 0.2rem; }
.media-info small { display: block; margin-bottom: 0.5rem; color: var(--text-muted); }

/* ============================================
   MODAL
   ============================================ */
.modal {
  display: none;
  position: fixed;
  inset: 0;
  background: rgba(0, 0, 0, 0.8);
  backdrop-filter: blur(8px);
  z-index: 200;
  align-items: center;
  justify-content: center;
  padding: 1rem;
}
.modal.open { display: flex; animation: fadeIn 0.2s; }
@keyframes fadeIn { from { opacity: 0; } to { opacity: 1; } }
.modal-content {
  background: var(--bg-2);
  border: 1px solid var(--border-hover);
  border-radius: var(--radius);
  padding: 2rem;
  max-width: 520px;
  width: 100%;
  max-height: 90vh;
  overflow-y: auto;
  box-shadow: 0 30px 80px rgba(0, 0, 0, 0.8), 0 0 40px rgba(177, 74, 237, 0.2);
  animation: slideUp 0.3s ease;
}
@keyframes slideUp {
  from { transform: translateY(20px); opacity: 0; }
  to { transform: translateY(0); opacity: 1; }
}
.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 1.25rem;
  padding-bottom: 0.85rem;
  border-bottom: 1px solid var(--border);
}
.modal-header h3 {
  font-family: 'Orbitron', sans-serif;
  font-size: 1rem;
  font-weight: 700;
}
.modal-close {
  background: none;
  border: none;
  color: var(--text-muted);
  cursor: pointer;
  font-size: 1.3rem;
  padding: 0.25rem;
  transition: color var(--transition);
}
.modal-close:hover { color: var(--neon-red); }

/* ============================================
   PROFILE
   ============================================ */
.profile-grid {
  display: flex;
  gap: 1.5rem;
  align-items: center;
  flex-wrap: wrap;
  margin-bottom: 1rem;
}
.profile-avatar {
  width: 100px; height: 100px;
  border-radius: 50%;
  background: var(--gradient-1);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 2.5rem;
  font-weight: 900;
  color: white;
  font-family: 'Orbitron', sans-serif;
  box-shadow: 0 0 40px rgba(177, 74, 237, 0.5);
  flex-shrink: 0;
}
.profile-meta { display: flex; flex-direction: column; gap: 0.35rem; font-size: 0.9rem; }
.upgrade-card {
  text-align: center;
  background: linear-gradient(135deg, rgba(177, 74, 237, 0.1), rgba(0, 240, 255, 0.07));
}

/* ============================================
   CONSOLE / LOGS
   ============================================ */
.console {
  background: #000;
  border: 1px solid rgba(0, 255, 157, 0.3);
  border-radius: 10px;
  padding: 1rem;
  font-family: 'JetBrains Mono', monospace;
  font-size: 0.82rem;
  height: 380px;
  overflow-y: auto;
  color: var(--neon-green);
  box-shadow: inset 0 0 30px rgba(0, 0, 0, 0.5);
  line-height: 1.6;
}
.console-line { padding: 1px 0; word-wrap: break-word; }
.console-time { color: var(--text-muted); margin-right: 8px; }
.log-info { color: var(--neon-cyan); }
.log-success { color: var(--neon-green); }
.log-warn { color: var(--neon-yellow); }
.log-error { color: var(--neon-red); }

/* ============================================
   ERROR PAGES
   ============================================ */
.error-page {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 1rem;
  padding: 2rem;
  text-align: center;
}
.error-code {
  font-family: 'Orbitron', sans-serif;
  font-size: 8rem;
  font-weight: 900;
  background: var(--gradient-1);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  animation: glitch 3s infinite;
  line-height: 1;
}
@keyframes glitch {
  0%, 90%, 100% { transform: translate(0); }
  92% { transform: translate(-3px, 2px); filter: hue-rotate(90deg); }
  94% { transform: translate(3px, -2px); filter: hue-rotate(-90deg); }
  96% { transform: translate(0); }
}

/* ============================================
   NEON DIVIDER
   ============================================ */
.neon-line {
  height: 1px;
  background: var(--gradient-1);
  margin: 1.5rem 0;
  opacity: 0.4;
}

/* ============================================
   TOAST NOTIFICATIONS
   ============================================ */
.toast-container {
  position: fixed;
  top: 1.25rem;
  right: 1.25rem;
  z-index: 999;
  display: flex;
  flex-direction: column;
  gap: 0.5rem;
  pointer-events: none;
}
.toast {
  background: rgba(10, 10, 25, 0.95);
  backdrop-filter: blur(20px);
  border: 1px solid var(--border);
  border-radius: 10px;
  padding: 0.85rem 1.1rem;
  min-width: 240px;
  max-width: 380px;
  font-size: 0.88rem;
  animation: toastIn 0.3s ease;
  display: flex;
  align-items: center;
  gap: 0.6rem;
  box-shadow: 0 10px 30px rgba(0,0,0,0.6);
  pointer-events: all;
}
.toast-info { border-color: rgba(0, 240, 255, 0.4); }
.toast-success { border-color: rgba(0, 255, 157, 0.4); }
.toast-error { border-color: rgba(255, 56, 96, 0.4); }
.toast-warn { border-color: rgba(255, 215, 0, 0.4); }
@keyframes toastIn {
  from { transform: translateX(120%); opacity: 0; }
  to { transform: translateX(0); opacity: 1; }
}

/* ============================================
   MUTED / UTILITIES
   ============================================ */
.muted { color: var(--text-muted); }
.small { font-size: 0.82rem; }
.text-glow { text-shadow: 0 0 10px currentColor; }
.text-center { text-align: center; }
.text-right { text-align: right; }
.flex { display: flex; }
.flex-col { flex-direction: column; }
.flex-1 { flex: 1; }
.items-center { align-items: center; }
.justify-between { justify-content: space-between; }
.justify-center { justify-content: center; }
.flex-wrap { flex-wrap: wrap; }
.gap-1 { gap: 0.35rem; }
.gap-2 { gap: 0.6rem; }
.gap-3 { gap: 0.85rem; }
.gap-4 { gap: 1.1rem; }
.gap-6 { gap: 1.5rem; }
.mb-0 { margin-bottom: 0; }
.mb-1 { margin-bottom: 0.5rem; }
.mb-2 { margin-bottom: 1rem; }
.mb-3 { margin-bottom: 1.5rem; }
.mt-1 { margin-top: 0.5rem; }
.mt-2 { margin-top: 1rem; }
.mt-3 { margin-top: 1.5rem; }
.w-full { width: 100%; }
.truncate { overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }

/* ============================================
   RESPONSIVE
   ============================================ */
@media (max-width: 900px) {
  .menu-toggle { display: flex; align-items: center; justify-content: center; }
  .sidebar {
    position: fixed;
    left: calc(-1 * var(--sidebar-w) - 20px);
    transition: left 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    z-index: 50;
    box-shadow: none;
  }
  .sidebar.open {
    left: 0;
    box-shadow: 15px 0 50px rgba(0,0,0,0.6);
  }
  .sidebar-overlay.open { display: block; }
  .main { max-width: 100%; padding: 4.5rem 1rem 1.5rem; }
  .page-header h1 { font-size: 1.3rem; }
  .stats-grid { grid-template-columns: repeat(2, 1fr); }
  .stat-value { font-size: 1.35rem; }
  .auth-card { padding: 2rem 1.5rem; }
  .pair-code { font-size: 1.7rem; }
  .quick-grid { grid-template-columns: 1fr; }
}
@media (max-width: 480px) {
  .stats-grid { grid-template-columns: 1fr 1fr; }
  .connect-grid { grid-template-columns: 1fr; }
  .form-grid { grid-template-columns: 1fr; }
  .auth-title { font-size: 1.5rem; }
}

/* ============================================
   PREMIUM PLAN CARDS
   ============================================ */
.plan-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
  gap: 1rem;
}
.plan-card {
  border: 1px solid var(--border);
  border-radius: var(--radius);
  padding: 1.5rem;
  background: var(--bg-1);
  transition: all var(--transition);
  text-align: center;
  position: relative;
  overflow: hidden;
}
.plan-card.featured {
  border-color: var(--neon-purple);
  background: linear-gradient(135deg, rgba(177,74,237,0.1), rgba(0,240,255,0.05));
  box-shadow: 0 0 30px rgba(177,74,237,0.2);
}
.plan-card:hover { transform: translateY(-4px); border-color: rgba(177,74,237,0.5); }
.plan-name {
  font-family: 'Orbitron', sans-serif;
  font-size: 0.8rem;
  text-transform: uppercase;
  letter-spacing: 2px;
  color: var(--text-muted);
  margin-bottom: 0.5rem;
}
.plan-price {
  font-family: 'Orbitron', sans-serif;
  font-size: 1.8rem;
  font-weight: 900;
  background: var(--gradient-gold);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  margin-bottom: 0.25rem;
}
.plan-period { font-size: 0.78rem; color: var(--text-muted); margin-bottom: 1rem; }
.plan-badge {
  position: absolute;
  top: 0.75rem; right: 0.75rem;
  background: var(--gradient-gold);
  color: #000;
  font-size: 0.6rem;
  font-weight: 900;
  letter-spacing: 1px;
  padding: 2px 8px;
  border-radius: 999px;
  text-transform: uppercase;
  font-family: 'Orbitron', sans-serif;
}

/* ============================================
   DECRYPTER RESULT
   ============================================ */
.decrypt-result {
  background: var(--bg-1);
  border: 1px solid var(--border);
  border-radius: var(--radius);
  overflow: hidden;
}
.decrypt-result-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 0.85rem 1rem;
  background: rgba(0, 240, 255, 0.05);
  border-bottom: 1px solid var(--border);
}
.decrypt-field {
  display: flex;
  align-items: center;
  gap: 0.75rem;
  padding: 0.7rem 1rem;
  border-bottom: 1px solid var(--border);
  transition: background var(--transition);
  font-size: 0.9rem;
}
.decrypt-field:last-child { border-bottom: none; }
.decrypt-field:hover { background: rgba(177, 74, 237, 0.05); }
.decrypt-field-label {
  font-size: 0.72rem;
  color: var(--text-muted);
  text-transform: uppercase;
  letter-spacing: 1px;
  width: 130px;
  flex-shrink: 0;
  font-family: 'Orbitron', sans-serif;
  font-weight: 700;
}
.decrypt-field-value {
  font-family: 'JetBrains Mono', monospace;
  font-size: 0.85rem;
  color: var(--neon-green);
  word-break: break-all;
  flex: 1;
}
