<%- include('../partials/head') %>
<div class="auth-wrapper">
  <div class="auth-bg"></div>
  <div class="auth-card">
    <div class="auth-logo">🆕</div>
    <h1 class="auth-title">Criar Conta Free</h1>
    <p class="auth-subtitle">Acesse o <%= bot.name %></p>

    <% if (error) { %>
      <div class="alert alert-error"><%= error %></div>
    <% } %>

    <form method="POST" action="/register" class="auth-form">
      <div class="form-group">
        <label>👤 Nome de exibição</label>
        <input type="text" name="name" placeholder="Seu nome" />
      </div>
      <div class="form-group">
        <label>🔤 Usuário (login)</label>
        <input type="text" name="username" required placeholder="ex: joao123" />
      </div>
      <div class="form-group">
        <label>📱 Número WhatsApp</label>
        <input type="text" name="whatsappNumber" placeholder="244XXXXXXXXX" />
      </div>
      <div class="form-group">
        <label>🔒 Senha</label>
        <input type="password" name="password" required placeholder="••••••••" />
      </div>
      <button type="submit" class="btn btn-primary btn-block">Criar conta</button>
    </form>

    <div class="auth-divider"><span>ou</span></div>
    <a href="/login" class="btn btn-ghost btn-block">Já tenho conta</a>
  </div>
</div>
<%- include('../partials/footer') %>
