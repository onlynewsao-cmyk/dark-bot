<%- include('../partials/head') %>
<div class="app-shell">
  <%- include('../partials/sidebar') %>
  <main class="main">
    <header class="page-header">
      <div>
        <h1>⚡ Comandos</h1>
        <p class="muted">Gerencie os comandos do <%= bot.name %></p>
      </div>
      <a href="/dashboard/commands/new" class="btn btn-primary">➕ Novo comando</a>
    </header>

    <div class="card">
      <div class="table-wrap">
        <table class="table">
          <thead>
            <tr>
              <th>Nome</th>
              <th>Categoria</th>
              <th>Acesso</th>
              <th>Mídia</th>
              <th>Usos</th>
              <th>Status</th>
              <th>Ações</th>
            </tr>
          </thead>
          <tbody>
            <% commands.forEach(cmd => { %>
              <tr>
                <td>
                  <strong><%= bot.prefix %><%= cmd.name %></strong>
                  <% if (cmd.aliases && cmd.aliases.length) { %>
                    <div class="muted small">alias: <%= cmd.aliases.join(', ') %></div>
                  <% } %>
                </td>
                <td><span class="chip"><%= cmd.category %></span></td>
                <td>
                  <% if (cmd.accessLevel === 'owner') { %><span class="chip chip-owner">👑 Dono</span>
                  <% } else if (cmd.accessLevel === 'premium') { %><span class="chip chip-premium">⭐ Premium</span>
                  <% } else { %><span class="chip chip-free">🆓 Todos</span><% } %>
                </td>
                <td><%= cmd.mediaType || '—' %></td>
                <td><%= cmd.usageCount || 0 %></td>
                <td>
                  <% if (cmd.enabled) { %><span class="chip chip-success">Ativo</span>
                  <% } else { %><span class="chip chip-muted">Inativo</span><% } %>
                </td>
                <td>
                  <a href="/dashboard/commands/<%= cmd._id %>/edit" class="btn btn-sm">✏️</a>
                  <button class="btn btn-sm btn-danger" onclick="delCmd('<%= cmd._id %>')">🗑️</button>
                </td>
              </tr>
            <% }) %>
            <% if (commands.length === 0) { %>
              <tr><td colspan="7" class="text-center muted">Nenhum comando ainda. Crie o primeiro!</td></tr>
            <% } %>
          </tbody>
        </table>
      </div>
    </div>
  </main>
</div>
<script>
  async function delCmd(id) {
    if (!confirm('Deletar este comando?')) return;
    await fetch('/api/commands/' + id, { method: 'DELETE' });
    location.reload();
  }
</script>
<%- include('../partials/footer') %>
