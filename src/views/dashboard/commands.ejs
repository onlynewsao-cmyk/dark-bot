<%- include('../partials/head') %>
<div class="app-shell">
  <%- include('../partials/sidebar') %>
  <main class="main">
    <header class="page-header">
      <div>
        <h1>⚡ Editor de Comandos</h1>
        <p class="muted">Gerencie todos os comandos (nativos + customizados). Total: <strong><%= totalCount %></strong></p>
      </div>
      <div class="button-row">
        <a href="/dashboard/commands/new" class="btn btn-primary">➕ Comando Custom</a>
        <button class="btn btn-ghost" onclick="document.getElementById('searchInput').focus()">🔍 Buscar</button>
      </div>
    </header>

    <div class="card">
      <div class="form-group">
        <input type="text" id="searchInput" placeholder="🔍 Buscar comando..." oninput="filterCommands(this.value)" />
      </div>
      <div class="button-row" style="flex-wrap:wrap;gap:.4rem">
        <button class="btn btn-sm" onclick="filterCat('')">📋 Todos</button>
        <% Object.entries(categories).forEach(([key, cat]) => { %>
          <button class="btn btn-sm" onclick="filterCat('<%= key %>')" style="border-color:<%= cat.color %>;color:<%= cat.color %>"><%= cat.emoji %> <%= cat.name.replace(/^[^\s]+\s/, '') %></button>
        <% }); %>
      </div>
    </div>

    <!-- Comandos custom do banco -->
    <% if (customCommands.length) { %>
    <div class="card" style="border-color:var(--neon-cyan)">
      <h2>⚙️ Comandos Customizados (do banco)</h2>
      <div class="table-wrap">
        <table class="table">
          <thead><tr><th>Nome</th><th>Categoria</th><th>Acesso</th><th>Mídia</th><th>Usos</th><th>Status</th><th>Ações</th></tr></thead>
          <tbody>
            <% customCommands.forEach(cmd => { %>
              <tr class="cmd-row" data-name="<%= cmd.name %>" data-category="<%= cmd.category %>">
                <td><strong><%= bot.prefix %><%= cmd.name %></strong>
                  <% if (cmd.aliases?.length) { %><div class="muted small">alias: <%= cmd.aliases.join(', ') %></div><% } %></td>
                <td><span class="chip"><%= cmd.category %></span></td>
                <td>
                  <% if (cmd.accessLevel === 'owner') { %><span class="chip chip-owner">👑 Dono</span>
                  <% } else if (cmd.accessLevel === 'premium') { %><span class="chip chip-premium">⭐ Premium</span>
                  <% } else { %><span class="chip chip-free">🆓 Todos</span><% } %>
                </td>
                <td><%= cmd.mediaType || '—' %></td>
                <td><%= cmd.usageCount || 0 %></td>
                <td><% if (cmd.enabled) { %><span class="chip chip-success">Ativo</span><% } else { %><span class="chip chip-muted">Off</span><% } %></td>
                <td>
                  <a href="/dashboard/commands/<%= cmd._id %>/edit" class="btn btn-sm">✏️</a>
                  <button class="btn btn-sm btn-danger" onclick="delCustom('<%= cmd._id %>')">🗑️</button>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    </div>
    <% } %>

    <!-- Comandos nativos por categoria -->
    <% Object.entries(catalog).forEach(([catKey, cmds]) => { %>
      <% if (cmds.length) { %>
        <% const catInfo = categories[catKey] || { name: catKey, emoji: '📁', color: '#888' }; %>
        <div class="card cat-section" data-category="<%= catKey %>" style="border-left:4px solid <%= catInfo.color %>">
          <h2 style="color:<%= catInfo.color %>"><%= catInfo.emoji %> <%= catInfo.name.replace(/^[^\s]+\s/, '') %> <span class="muted" style="font-size:.85rem;font-weight:normal">(<%= cmds.length %>)</span></h2>
          <div class="commands-grid">
            <% cmds.forEach(cmd => {
              const ov = overrides[cmd.name] || {};
              const enabled = ov.enabled !== false;
              const displayName = ov.displayName || cmd.name;
              const emoji = ov.emoji || cmd.emoji;
              const description = ov.description || cmd.description;
            %>
              <div class="command-card cmd-row" data-name="<%= cmd.name %>" data-category="<%= cmd.category %>" style="<%= !enabled ? 'opacity:0.5' : '' %>">
                <div class="command-header">
                  <span class="command-emoji"><%= emoji %></span>
                  <div>
                    <div class="command-name"><%= bot.prefix %><%= cmd.name %></div>
                    <% if (displayName !== cmd.name) { %><div class="muted small">"<%= displayName %>"</div><% } %>
                  </div>
                  <span class="command-status">
                    <% if (cmd.ownerOnly) { %><span class="chip chip-owner" style="font-size:.65rem">👑</span><% } %>
                    <% if (cmd.premium) { %><span class="chip chip-premium" style="font-size:.65rem">⭐</span><% } %>
                  </span>
                </div>
                <div class="command-desc"><%= description %></div>
                <div class="command-actions">
                  <button class="btn btn-sm" onclick="editNative('<%= cmd.name %>')">✏️ Editar</button>
                  <button class="btn btn-sm <%= enabled ? 'btn-danger' : 'btn-success' %>" onclick="toggleNative('<%= cmd.name %>', <%= !enabled %>)">
                    <%= enabled ? '🔴 Off' : '🟢 On' %>
                  </button>
                  <% if (ov.mediaUrl) { %><span title="Tem mídia">🎁</span><% } %>
                </div>
              </div>
            <% }) %>
          </div>
        </div>
      <% } %>
    <% }) %>

    <!-- Modal de edição de comando nativo -->
    <div class="modal" id="editModal">
      <div class="modal-content" style="max-width:600px">
        <h2>✏️ Editar Comando <span id="editCmdName"></span></h2>
        <form id="editForm">
          <input type="hidden" id="editName" />

          <div class="form-grid">
            <div class="form-group">
              <label>📛 Nome de exibição (apelido no menu)</label>
              <input type="text" id="editDisplayName" placeholder="Deixe vazio pro padrão" />
            </div>
            <div class="form-group">
              <label>🎨 Emoji</label>
              <input type="text" id="editEmoji" placeholder="🤖" />
            </div>
          </div>

          <div class="form-group">
            <label>📝 Descrição</label>
            <input type="text" id="editDescription" placeholder="O que o comando faz" />
          </div>

          <div class="form-group">
            <label>🔗 Aliases (separados por vírgula)</label>
            <input type="text" id="editAliases" placeholder="alias1, alias2" />
          </div>

          <div class="form-grid">
            <div class="form-group">
              <label>🏷️ Categoria</label>
              <select id="editCategory">
                <% Object.entries(categories).forEach(([k,c]) => { %>
                  <option value="<%= k %>"><%= c.emoji %> <%= c.name.replace(/^[^\s]+\s/, '') %></option>
                <% }) %>
              </select>
            </div>
            <div class="form-group">
              <label>🔐 Acesso</label>
              <select id="editAccess">
                <option value="all">🆓 Todos</option>
                <option value="premium">⭐ Premium</option>
                <option value="owner">👑 Dono</option>
              </select>
            </div>
          </div>

          <div class="form-grid">
            <div class="form-group">
              <label>🎁 Mídia anexa (URL Cloudinary)</label>
              <select id="editMediaUrl">
                <option value="">— sem —</option>
                <% medias.forEach(m => { %>
                  <option value="<%= m.url %>" data-type="<%= m.type %>">[<%= m.type %>] <%= m.name %></option>
                <% }) %>
              </select>
              <small class="muted">Será enviada junto com a resposta</small>
            </div>
            <div class="form-group">
              <label>📦 Tipo de mídia</label>
              <select id="editMediaType">
                <option value="">—</option>
                <option value="image">🖼️ Imagem</option>
                <option value="video">🎬 Vídeo</option>
                <option value="gif">✨ GIF</option>
                <option value="audio">🎵 Áudio</option>
              </select>
            </div>
          </div>

          <div class="form-group">
            <label>💬 Resposta customizada (opcional)</label>
            <textarea id="editResponse" rows="4" placeholder="Deixe vazio pra usar a resposta padrão do comando.&#10;&#10;Use: {user} {bot} {owner} {group}"></textarea>
          </div>

          <div class="form-grid">
            <div class="form-group form-check">
              <label><input type="checkbox" id="editEnabled" checked /> Comando ATIVO</label>
            </div>
            <div class="form-group form-check">
              <label><input type="checkbox" id="editUseCustom" /> Usar resposta customizada</label>
            </div>
          </div>

          <div class="button-row">
            <button type="submit" class="btn btn-primary">💾 Salvar</button>
            <button type="button" class="btn btn-danger" onclick="resetNative()">🔄 Resetar para padrão</button>
            <button type="button" class="btn btn-ghost" onclick="closeModal()">Cancelar</button>
          </div>
        </form>
      </div>
    </div>
  </main>
</div>

<style>
  .commands-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 1rem;
    margin-top: 1rem;
  }
  .command-card {
    background: var(--bg-1);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 1rem;
    transition: all 0.3s;
  }
  .command-card:hover {
    border-color: var(--neon-cyan);
    transform: translateY(-2px);
  }
  .command-header {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    margin-bottom: 0.5rem;
  }
  .command-emoji { font-size: 1.5rem; }
  .command-name {
    font-family: 'JetBrains Mono', monospace;
    font-weight: 700;
    color: var(--neon-cyan);
    font-size: 0.95rem;
  }
  .command-status { margin-left: auto; }
  .command-desc {
    color: var(--text-muted);
    font-size: 0.85rem;
    margin-bottom: 0.75rem;
    min-height: 2rem;
  }
  .command-actions {
    display: flex;
    gap: 0.4rem;
    flex-wrap: wrap;
  }
</style>

<script>
  const medias = <%- JSON.stringify(medias) %>;
  const overrides = <%- JSON.stringify(overrides) %>;
  let currentCat = '';
  let currentSearch = '';

  function filterCommands(text) {
    currentSearch = text.toLowerCase();
    applyFilters();
  }
  function filterCat(cat) {
    currentCat = cat;
    applyFilters();
  }
  function applyFilters() {
    document.querySelectorAll('.cmd-row').forEach(r => {
      const name = r.dataset.name?.toLowerCase() || '';
      const cat = r.dataset.category || '';
      const matchSearch = !currentSearch || name.includes(currentSearch);
      const matchCat = !currentCat || cat === currentCat;
      r.style.display = matchSearch && matchCat ? '' : 'none';
    });
    document.querySelectorAll('.cat-section').forEach(s => {
      const visible = [...s.querySelectorAll('.cmd-row')].some(r => r.style.display !== 'none');
      s.style.display = visible ? '' : 'none';
    });
  }

  async function editNative(name) {
    const ov = overrides[name] || {};
    document.getElementById('editName').value = name;
    document.getElementById('editCmdName').textContent = '!' + name;
    document.getElementById('editDisplayName').value = ov.displayName || '';
    document.getElementById('editEmoji').value = ov.emoji || '';
    document.getElementById('editDescription').value = ov.description || '';
    document.getElementById('editAliases').value = (ov.aliases || []).join(', ');
    document.getElementById('editCategory').value = ov.category || '';
    document.getElementById('editAccess').value = ov.accessLevel || 'all';
    document.getElementById('editMediaUrl').value = ov.mediaUrl || '';
    document.getElementById('editMediaType').value = ov.mediaType || '';
    document.getElementById('editResponse').value = ov.customResponse || '';
    document.getElementById('editEnabled').checked = ov.enabled !== false;
    document.getElementById('editUseCustom').checked = !!ov.useCustomResponse;
    document.getElementById('editModal').classList.add('open');
  }

  function closeModal() {
    document.getElementById('editModal').classList.remove('open');
  }

  document.getElementById('editMediaUrl').onchange = (e) => {
    const t = e.target.selectedOptions[0]?.dataset?.type;
    if (t) document.getElementById('editMediaType').value = t;
  };

  document.getElementById('editForm').onsubmit = async (e) => {
    e.preventDefault();
    const name = document.getElementById('editName').value;
    const data = {
      displayName: document.getElementById('editDisplayName').value,
      emoji: document.getElementById('editEmoji').value,
      description: document.getElementById('editDescription').value,
      aliases: document.getElementById('editAliases').value.split(',').map(s=>s.trim()).filter(Boolean),
      category: document.getElementById('editCategory').value,
      accessLevel: document.getElementById('editAccess').value,
      mediaUrl: document.getElementById('editMediaUrl').value,
      mediaType: document.getElementById('editMediaType').value,
      customResponse: document.getElementById('editResponse').value,
      enabled: document.getElementById('editEnabled').checked,
      useCustomResponse: document.getElementById('editUseCustom').checked,
    };
    try {
      const r = await fetch(`/api/commands/override/${name}`, {
        method: 'POST', headers: {'Content-Type':'application/json'},
        body: JSON.stringify(data),
      });
      if (r.ok) { toast('✅ Salvo!', 'success'); setTimeout(()=>location.reload(), 800); }
      else toast('❌ Erro', 'error');
    } catch (err) { toast('Erro: '+err.message, 'error'); }
  };

  async function toggleNative(name, enabled) {
    try {
      await fetch(`/api/commands/override/${name}`, {
        method: 'POST', headers: {'Content-Type':'application/json'},
        body: JSON.stringify({ enabled }),
      });
      toast(enabled ? '🟢 Ativado' : '🔴 Desativado', 'success', 1500);
      setTimeout(()=>location.reload(), 600);
    } catch (e) { toast(e.message, 'error'); }
  }

  async function resetNative() {
    if (!confirm('Resetar este comando para o padrão?')) return;
    const name = document.getElementById('editName').value;
    try {
      await fetch(`/api/commands/override/${name}`, { method: 'DELETE' });
      toast('🔄 Resetado', 'success');
      setTimeout(()=>location.reload(), 600);
    } catch (e) { toast(e.message, 'error'); }
  }

  async function delCustom(id) {
    if (!confirm('Deletar este comando customizado?')) return;
    await fetch('/api/commands/' + id, { method: 'DELETE' });
    location.reload();
  }
</script>
<%- include('../partials/footer') %>
