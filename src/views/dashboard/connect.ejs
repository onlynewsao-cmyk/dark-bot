<%- include('../partials/head') %>
<div class="app-shell">
  <%- include('../partials/sidebar') %>
  <main class="main">
    <header class="page-header">
      <div>
        <h1>🔌 Conectar Bot</h1>
        <p class="muted">Conecte o <%= bot.name %> ao WhatsApp via QR Code ou Pair Code</p>
      </div>
      <div class="bot-status" id="botStatusBadge">
        <span class="status-dot status-<%= botState.status %>"></span>
        <span id="botStatusText"><%= botState.status %></span>
      </div>
    </header>

    <div class="alert alert-info" id="connInstructions">
      <span>💡</span>
      <span><strong>Como usar:</strong> Clique em "Gerar QR" ou "Gerar Pair Code". O código aparecerá em segundos (pode levar 5-30s no Render Free).</span>
    </div>

    <div class="connect-grid">
      <!-- QR CODE -->
      <div class="card">
        <h2>📱 QR Code</h2>
        <p class="muted">Escaneie pelo WhatsApp → Aparelhos Conectados</p>
        <div class="qr-area" id="qrArea">
          <% if (botState.qr) { %>
            <img src="<%= botState.qr %>" alt="QR Code" />
          <% } else if (botState.status === 'connected') { %>
            <div class="qr-placeholder success">
              <div class="qr-icon">✅</div>
              <p><strong>Bot conectado!</strong></p>
            </div>
          <% } else { %>
            <div class="qr-placeholder">
              <div class="qr-icon">📷</div>
              <p>Clique no botão abaixo</p>
            </div>
          <% } %>
        </div>
        <button class="btn btn-primary btn-block" id="btnQR" type="button">
          <span>🔄</span> Gerar QR Code
        </button>
      </div>

      <!-- PAIR CODE -->
      <div class="card">
        <h2>🔢 Pair Code (8 dígitos)</h2>
        <p class="muted">Digite seu número e receba um código</p>
        <div class="form-group">
          <label>📞 Número WhatsApp (com DDI, sem +)</label>
          <input type="text" id="phoneNumber" placeholder="244949926074" value="<%= bot.number %>" />
        </div>
        <div class="pair-area" id="pairArea">
          <% if (botState.pairingCode) { %>
            <div>
              <div class="pair-code"><%= botState.pairingCode %></div>
              <p class="muted text-center">Insira este código no WhatsApp</p>
            </div>
          <% } else if (botState.status === 'connected') { %>
            <div class="qr-placeholder success">
              <div class="qr-icon">✅</div>
              <p><strong>Bot conectado!</strong></p>
            </div>
          <% } else { %>
            <div class="qr-placeholder">
              <div class="qr-icon">🔢</div>
              <p>Clique no botão abaixo</p>
            </div>
          <% } %>
        </div>
        <button class="btn btn-primary btn-block" id="btnPair" type="button">
          <span>🔄</span> Gerar Pair Code
        </button>
      </div>
    </div>

    <div class="card">
      <h3>⚙️ Controles & Status</h3>
      <div class="button-row" style="margin-bottom: 1rem;">
        <button class="btn btn-danger" id="btnLogout" type="button">🚪 Desconectar Bot</button>
        <button class="btn btn-ghost" id="btnRefresh" type="button">🔄 Atualizar Status</button>
        <button class="btn btn-danger" id="btnReset" type="button" style="background:rgba(255,56,96,.25)">🧹 RESET TOTAL (limpa sessão)</button>
        <span class="muted" id="connStatus">Status: <%= botState.status %></span>
      </div>
      <% if (botState.user) { %>
        <div class="alert alert-success" id="connectedInfo">
          <span>✅</span>
          <span>Conectado como: <strong><%= botState.user.id %></strong></span>
        </div>
      <% } %>
    </div>

    <!-- LOGS -->
    <div class="card">
      <h3>📜 Console em Tempo Real</h3>
      <div class="console" id="botConsole">
        <div class="console-line log-info">
          <span class="console-time">[--:--:--]</span> Carregando...
        </div>
      </div>
      <div class="button-row mt-1">
        <button class="btn btn-sm btn-ghost" type="button" onclick="document.getElementById('botConsole').innerHTML=''">🗑️ Limpar</button>
      </div>
    </div>
  </main>
</div>

<!-- Socket.IO opcional via CDN como fallback -->
<script src="https://cdn.socket.io/4.7.5/socket.io.min.js" integrity="sha384-2huaZvOR9iDzHqslqwpR87isEmrfxqyWOF7hr7BY6KG0+hVKLoEXMPUJw3ynWuhO" crossorigin="anonymous"></script>

<script>
  // ============ ESTADO E DOM ============
  const qrArea = document.getElementById('qrArea');
  const pairArea = document.getElementById('pairArea');
  const statusText = document.getElementById('botStatusText');
  const statusDot = document.querySelector('#botStatusBadge .status-dot');
  const connStatus = document.getElementById('connStatus');
  const botConsole = document.getElementById('botConsole');

  let lastQr = '<%= botState.qr || "" %>';
  let lastPair = '<%= botState.pairingCode || "" %>';
  let lastStatus = '<%= botState.status %>';
  let lastLogIdx = 0;
  let pollTimer = null;
  let pollInterval = 2000; // 2 segundos

  // ============ LOG HELPER ============
  function logToConsole(level, message) {
    const time = new Date().toLocaleTimeString('pt-BR');
    const line = document.createElement('div');
    line.className = 'console-line log-' + level;
    line.innerHTML = '<span class="console-time">[' + time + ']</span> ' + message;
    botConsole.appendChild(line);
    botConsole.scrollTop = botConsole.scrollHeight;
    if (botConsole.children.length > 200) botConsole.removeChild(botConsole.firstChild);
  }

  // ============ TOAST FALLBACK ============
  if (typeof toast === 'undefined') {
    window.toast = function(msg, type) {
      console.log('[' + (type || 'info') + ']', msg);
      logToConsole(type || 'info', msg);
    };
  }

  // ============ UI UPDATE ============
  function updateUI(data) {
    if (!data) return;

    if (data.status && data.status !== lastStatus) {
      lastStatus = data.status;
      statusText.textContent = data.status;
      statusDot.className = 'status-dot status-' + data.status;
      connStatus.textContent = 'Status: ' + data.status;
      logToConsole('info', '📡 Status: ' + data.status);
    }

    if (data.qr && data.qr !== lastQr) {
      lastQr = data.qr;
      qrArea.innerHTML = '<img src="' + data.qr + '" alt="QR Code" />';
      logToConsole('success', '📱 QR Code recebido! Escaneie agora.');
      toast('QR Code pronto! Escaneie pelo WhatsApp', 'success');
    }

    if (data.pairingCode && data.pairingCode !== lastPair) {
      lastPair = data.pairingCode;
      pairArea.innerHTML =
        '<div>' +
          '<div class="pair-code">' + data.pairingCode + '</div>' +
          '<p class="muted text-center">Digite este código no WhatsApp</p>' +
        '</div>';
      logToConsole('success', '🔐 Pair Code: ' + data.pairingCode);
      toast('Pair Code: ' + data.pairingCode, 'success');
    }

    if (data.status === 'connected') {
      qrArea.innerHTML = '<div class="qr-placeholder success"><div class="qr-icon">✅</div><p><strong>Bot conectado!</strong></p></div>';
      pairArea.innerHTML = '<div class="qr-placeholder success"><div class="qr-icon">✅</div><p><strong>Bot conectado!</strong></p></div>';
      // Para o polling rápido
      if (pollInterval < 10000) {
        pollInterval = 10000;
        restartPolling();
      }
    }

    // Logs recentes
    if (data.recentLogs && Array.isArray(data.recentLogs)) {
      for (let i = lastLogIdx; i < data.recentLogs.length; i++) {
        const log = data.recentLogs[i];
        logToConsole(log.level || 'info', log.message);
      }
      lastLogIdx = data.recentLogs.length;
    }
  }

  // ============ POLLING (sempre funciona) ============
  async function pollStatus() {
    try {
      const res = await fetch('/api/bot/status', { cache: 'no-store' });
      if (!res.ok) throw new Error('HTTP ' + res.status);
      const data = await res.json();
      updateUI(data);
    } catch (err) {
      console.error('Poll error:', err);
    }
  }

  function startPolling() {
    if (pollTimer) clearInterval(pollTimer);
    pollTimer = setInterval(pollStatus, pollInterval);
  }
  function restartPolling() { startPolling(); }

  // Primeira chamada imediata
  pollStatus();
  startPolling();
  logToConsole('info', '🔄 Polling iniciado (a cada ' + (pollInterval/1000) + 's)');

  // ============ SOCKET.IO (bonus se disponível) ============
  if (typeof io !== 'undefined') {
    try {
      const socket = io({
        transports: ['polling', 'websocket'],
        reconnection: true,
        reconnectionDelay: 1000,
      });
      socket.on('connect', () => {
        logToConsole('success', '🔗 Socket.IO conectado (tempo real)');
      });
      socket.on('disconnect', () => {
        logToConsole('warn', '⚠️ Socket.IO desconectado (usando polling)');
      });
      socket.on('bot:status', (data) => updateUI(data));
      socket.on('bot:log', (data) => logToConsole(data.level || 'info', data.message));
      socket.on('bot:error', (data) => {
        toast('Erro: ' + data.message, 'error');
        logToConsole('error', '❌ ' + data.message);
      });
    } catch (e) {
      logToConsole('warn', 'Socket.IO falhou - usando polling apenas');
    }
  } else {
    logToConsole('warn', 'Socket.IO não disponível - usando polling apenas');
  }

  // ============ BOTÕES ============
  document.getElementById('btnQR').addEventListener('click', async () => {
    qrArea.innerHTML = '<div class="qr-placeholder"><div class="spinner"></div><p>Solicitando QR Code...</p><small class="muted">Aguarde 10-30 segundos</small></div>';
    logToConsole('info', '🔄 Solicitando geração de QR Code...');
    lastQr = ''; // reset para detectar novo
    pollInterval = 1500;
    restartPolling();
    try {
      const res = await fetch('/api/bot/connect', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ mode: 'qr' }),
      });
      const data = await res.json();
      if (!res.ok) throw new Error(data.error || 'erro');
      logToConsole('success', '✅ Comando enviado, aguardando QR...');
    } catch (err) {
      logToConsole('error', '❌ ' + err.message);
      qrArea.innerHTML = '<div class="qr-placeholder"><div class="qr-icon">❌</div><p>Erro: ' + err.message + '</p></div>';
    }
  });

  document.getElementById('btnPair').addEventListener('click', async () => {
    const phone = document.getElementById('phoneNumber').value.trim().replace(/\D/g, '');
    if (!phone || phone.length < 10) {
      logToConsole('error', '❌ Número inválido! Use formato 244949926074');
      alert('Número inválido! Use formato com DDI (ex: 244949926074)');
      return;
    }
    pairArea.innerHTML = '<div class="qr-placeholder"><div class="spinner"></div><p>Solicitando Pair Code...</p><small class="muted">Aguarde 10-30 segundos</small></div>';
    logToConsole('info', '🔄 Solicitando Pair Code para ' + phone + '...');
    lastPair = '';
    pollInterval = 1500;
    restartPolling();
    try {
      const res = await fetch('/api/bot/connect', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ mode: 'pair', phoneNumber: phone }),
      });
      const data = await res.json();
      if (!res.ok) throw new Error(data.error || 'erro');
      logToConsole('success', '✅ Comando enviado, aguardando código...');
    } catch (err) {
      logToConsole('error', '❌ ' + err.message);
      pairArea.innerHTML = '<div class="qr-placeholder"><div class="qr-icon">❌</div><p>Erro: ' + err.message + '</p></div>';
    }
  });

  document.getElementById('btnLogout').addEventListener('click', async () => {
    if (!confirm('Tem certeza? Isso vai desconectar o bot e limpar a sessão.')) return;
    try {
      await fetch('/api/bot/logout', { method: 'POST' });
      logToConsole('warn', '🚪 Bot desconectado');
      lastQr = ''; lastPair = '';
      qrArea.innerHTML = '<div class="qr-placeholder"><div class="qr-icon">📷</div><p>Clique no botão abaixo</p></div>';
      pairArea.innerHTML = '<div class="qr-placeholder"><div class="qr-icon">🔢</div><p>Clique no botão abaixo</p></div>';
    } catch (err) { logToConsole('error', '❌ ' + err.message); }
  });

  document.getElementById('btnReset').addEventListener('click', async () => {
    if (!confirm('ATENÇÃO: Isso vai apagar TODA a sessão (banco + arquivos). Tem certeza?')) return;
    logToConsole('warn', '🧹 Resetando tudo...');
    try {
      const r = await fetch('/api/bot/reset', { method: 'POST' });
      const d = await r.json();
      if (r.ok) {
        logToConsole('success', '✅ Reset feito! Agora clique em "Gerar QR" ou "Gerar Pair Code"');
        lastQr = ''; lastPair = '';
        qrArea.innerHTML = '<div class="qr-placeholder"><div class="qr-icon">🧹</div><p><strong>Sessão limpa!</strong><br>Clique abaixo pra gerar novo</p></div>';
        pairArea.innerHTML = '<div class="qr-placeholder"><div class="qr-icon">🧹</div><p><strong>Sessão limpa!</strong><br>Clique abaixo pra gerar novo</p></div>';
      } else throw new Error(d.error);
    } catch (e) { logToConsole('error', '❌ ' + e.message); }
  });

  document.getElementById('btnRefresh').addEventListener('click', () => {
    logToConsole('info', '🔄 Atualizando status...');
    pollStatus();
  });
</script>
<%- include('../partials/footer') %>
