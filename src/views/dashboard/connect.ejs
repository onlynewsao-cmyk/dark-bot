<%- include('../partials/head') %>
<div class="app-shell">
  <%- include('../partials/sidebar') %>
  <main class="main">
    <header class="page-header">
      <div>
        <h1>🔌 Conectar Bot</h1>
        <p class="muted">Conecte o <%= bot.name %> ao WhatsApp via QR Code ou Pair Code</p>
      </div>
      <div class="bot-status" id="botStatusBadge">
        <span class="status-dot status-<%= botState.status %>"></span>
        <span id="botStatusText"><%= botState.status %></span>
      </div>
    </header>

    <div class="alert alert-info" id="connInstructions">
      <span>💡</span>
      <span><strong>Como usar:</strong> Clique em "Gerar QR" ou "Gerar Pair Code". O código aparecerá em segundos. Use no WhatsApp → ⚙️ Configurações → Aparelhos conectados → Conectar aparelho.</span>
    </div>

    <div class="connect-grid">
      <!-- QR CODE -->
      <div class="card">
        <h2>📱 QR Code</h2>
        <p class="muted">Escaneie pelo WhatsApp</p>
        <div class="qr-area" id="qrArea">
          <% if (botState.qr) { %>
            <img src="<%= botState.qr %>" alt="QR Code" />
          <% } else if (botState.status === 'connected') { %>
            <div class="qr-placeholder success">
              <div class="qr-icon">✅</div>
              <p><strong>Bot conectado!</strong></p>
            </div>
          <% } else { %>
            <div class="qr-placeholder">
              <div class="qr-icon">📷</div>
              <p>Clique no botão abaixo</p>
            </div>
          <% } %>
        </div>
        <button class="btn btn-primary btn-block" id="btnQR">
          <span>🔄</span> Gerar QR Code
        </button>
      </div>

      <!-- PAIR CODE -->
      <div class="card">
        <h2>🔢 Pair Code (8 dígitos)</h2>
        <p class="muted">Digite seu número e receba um código</p>
        <div class="form-group">
          <label>📞 Número WhatsApp (com DDI)</label>
          <input type="text" id="phoneNumber" placeholder="244949926074" value="<%= bot.number %>" />
        </div>
        <div class="pair-area" id="pairArea">
          <% if (botState.pairingCode) { %>
            <div>
              <div class="pair-code"><%= botState.pairingCode %></div>
              <p class="muted text-center">Insira este código no WhatsApp</p>
            </div>
          <% } else if (botState.status === 'connected') { %>
            <div class="qr-placeholder success">
              <div class="qr-icon">✅</div>
              <p><strong>Bot conectado!</strong></p>
            </div>
          <% } else { %>
            <div class="qr-placeholder">
              <div class="qr-icon">🔢</div>
              <p>Clique no botão abaixo</p>
            </div>
          <% } %>
        </div>
        <button class="btn btn-primary btn-block" id="btnPair">
          <span>🔄</span> Gerar Pair Code
        </button>
      </div>
    </div>

    <div class="card">
      <h3>⚙️ Controles & Status</h3>
      <div class="button-row" style="margin-bottom: 1rem;">
        <button class="btn btn-danger" id="btnLogout">🚪 Desconectar Bot</button>
        <button class="btn btn-ghost" id="btnRefresh">🔄 Atualizar Status</button>
        <span class="muted" id="connStatus">Status: <%= botState.status %></span>
      </div>
      <% if (botState.user) { %>
        <div class="alert alert-success" id="connectedInfo">
          <span>✅</span>
          <span>Conectado como: <strong><%= botState.user.id %></strong></span>
        </div>
      <% } %>
    </div>

    <!-- LOGS DO BOT -->
    <div class="card">
      <h3>📜 Console do Bot (logs em tempo real)</h3>
      <div class="console" id="botConsole">
        <div class="console-line log-info">
          <span class="console-time">[--:--:--]</span> Aguardando eventos...
        </div>
      </div>
      <div class="button-row mt-1">
        <button class="btn btn-sm btn-ghost" onclick="document.getElementById('botConsole').innerHTML=''">🗑️ Limpar</button>
      </div>
    </div>
  </main>
</div>

<script>
  const socket = io({ reconnection: true, reconnectionDelay: 1000 });

  const qrArea = document.getElementById('qrArea');
  const pairArea = document.getElementById('pairArea');
  const statusText = document.getElementById('botStatusText');
  const statusDot = document.querySelector('#botStatusBadge .status-dot');
  const connStatus = document.getElementById('connStatus');
  const botConsole = document.getElementById('botConsole');

  function logToConsole(level, message) {
    const time = new Date().toLocaleTimeString('pt-BR');
    const line = document.createElement('div');
    line.className = `console-line log-${level}`;
    line.innerHTML = `<span class="console-time">[${time}]</span> ${message}`;
    botConsole.appendChild(line);
    botConsole.scrollTop = botConsole.scrollHeight;
    if (botConsole.children.length > 200) botConsole.removeChild(botConsole.firstChild);
  }

  socket.on('connect', () => {
    logToConsole('success', '🔗 Socket conectado');
    fetch('/api/bot/status').then(r => r.json()).then(updateUI);
  });

  socket.on('disconnect', () => logToConsole('warn', '⚠️ Socket desconectado'));

  socket.on('bot:status', (data) => {
    console.log('[bot:status]', data);
    updateUI(data);
  });

  socket.on('bot:log', (data) => {
    logToConsole(data.level || 'info', data.message);
  });

  socket.on('bot:error', (data) => {
    toast('Erro: ' + data.message, 'error', 6000);
    logToConsole('error', '❌ ' + data.message);
  });

  function updateUI(data) {
    if (!data) return;
    if (data.status) {
      statusText.textContent = data.status;
      statusDot.className = 'status-dot status-' + data.status;
      connStatus.textContent = 'Status: ' + data.status;
    }

    if (data.qr) {
      qrArea.innerHTML = `<img src="${data.qr}" alt="QR Code" />`;
      logToConsole('info', '📱 QR Code recebido');
    }
    if (data.pairingCode) {
      pairArea.innerHTML = `
        <div>
          <div class="pair-code">${data.pairingCode}</div>
          <p class="muted text-center">Insira este código no WhatsApp</p>
        </div>`;
      logToConsole('info', `🔐 Pair Code: ${data.pairingCode}`);
      toast('Pair Code gerado! Use no WhatsApp.', 'success');
    }
    if (data.status === 'connected') {
      qrArea.innerHTML = `<div class="qr-placeholder success"><div class="qr-icon">✅</div><p><strong>Bot conectado!</strong></p></div>`;
      pairArea.innerHTML = `<div class="qr-placeholder success"><div class="qr-icon">✅</div><p><strong>Bot conectado!</strong></p></div>`;
      toast('Bot conectado com sucesso! 🎉', 'success');
    }
    if (data.status === 'disconnected' && data.error) {
      toast('Desconectado: ' + data.error, 'error');
    }
  }

  document.getElementById('btnQR').addEventListener('click', async () => {
    qrArea.innerHTML = '<div class="qr-placeholder"><div class="spinner"></div><p>Gerando QR Code...</p><small class="muted">Pode levar 10-20 segundos</small></div>';
    logToConsole('info', '🔄 Solicitando QR Code...');
    try {
      const res = await fetch('/api/bot/connect', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ mode: 'qr' }),
      });
      const data = await res.json();
      if (!res.ok) throw new Error(data.error || 'erro');
      toast('Aguardando QR Code...', 'info');
    } catch (err) {
      toast('Erro: ' + err.message, 'error');
      qrArea.innerHTML = '<div class="qr-placeholder"><div class="qr-icon">❌</div><p>Erro</p></div>';
    }
  });

  document.getElementById('btnPair').addEventListener('click', async () => {
    const phone = document.getElementById('phoneNumber').value.trim().replace(/\D/g, '');
    if (!phone || phone.length < 10) {
      toast('Número inválido! Use formato com DDI (ex: 244949926074)', 'error');
      return;
    }
    pairArea.innerHTML = '<div class="qr-placeholder"><div class="spinner"></div><p>Gerando Pair Code...</p><small class="muted">Pode levar até 15s</small></div>';
    logToConsole('info', `🔄 Solicitando Pair Code para ${phone}...`);
    try {
      const res = await fetch('/api/bot/connect', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ mode: 'pair', phoneNumber: phone }),
      });
      const data = await res.json();
      if (!res.ok) throw new Error(data.error || 'erro');
      toast('Aguardando Pair Code...', 'info');
    } catch (err) {
      toast('Erro: ' + err.message, 'error');
      pairArea.innerHTML = '<div class="qr-placeholder"><div class="qr-icon">❌</div><p>Erro</p></div>';
    }
  });

  document.getElementById('btnLogout').addEventListener('click', async () => {
    if (!confirm('Tem certeza? Isso vai desconectar o bot e limpar a sessão.')) return;
    try {
      await fetch('/api/bot/logout', { method: 'POST' });
      toast('Bot desconectado', 'warn');
      logToConsole('warn', '🚪 Bot desconectado pelo usuário');
    } catch (err) { toast('Erro: ' + err.message, 'error'); }
  });

  document.getElementById('btnRefresh').addEventListener('click', async () => {
    const res = await fetch('/api/bot/status');
    const data = await res.json();
    updateUI(data);
    toast('Status atualizado', 'info', 2000);
  });
</script>
<%- include('../partials/footer') %>
