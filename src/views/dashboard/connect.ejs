<%- include('../partials/head') %>
<div class="app-shell">
  <%- include('../partials/sidebar') %>
  <main class="main">

    <header class="page-header">
      <div>
        <h1>🔌 Conectar Bot</h1>
        <p class="muted">Conecte o <%= bot.name %> ao WhatsApp via QR Code ou Pair Code</p>
      </div>
      <div class="bot-status" id="botStatusBadge">
        <span class="status-dot status-<%= botState.status %>"></span>
        <span id="botStatusText"><%= botState.status %></span>
      </div>
    </header>

    <div class="alert alert-info" id="connInstructions">
      <span>💡</span>
      <span><strong>Como conectar:</strong><br>
        <strong>QR Code:</strong> WhatsApp → Menu → Aparelhos conectados → Conectar → Escaneie o QR.<br>
        <strong>Pair Code:</strong> WhatsApp → Menu → Aparelhos conectados → Vincular com número → Digite o código.<br>
        <em>No Render, pode levar até 30s para aparecer.</em>
      </span>
    </div>

    <div id="connectedBanner" style="display:none">
      <div class="alert alert-success" style="border-color:var(--neon-green);background:rgba(0,255,157,.06)">
        <span style="font-size:1.8rem">✅</span>
        <div>
          <strong style="font-size:1.1rem">Bot conectado ao WhatsApp!</strong>
          <div id="connectedInfo" class="muted mt-1"></div>
        </div>
      </div>
      <div class="button-row mt-2">
        <button class="btn btn-danger" onclick="disconnectBot()">🔌 Desconectar</button>
        <button class="btn btn-warning" onclick="resetSession()">♻️ Reset Sessão</button>
      </div>
    </div>

    <div class="connect-grid">
      <!-- QR CODE CARD -->
      <div class="card" id="qrCard">
        <div style="display:flex;align-items:center;gap:.75rem;margin-bottom:1rem">
          <div style="width:48px;height:48px;border-radius:12px;background:linear-gradient(135deg,rgba(0,240,255,.2),rgba(177,74,237,.2));display:flex;align-items:center;justify-content:center;font-size:1.5rem;border:1px solid var(--border)">📱</div>
          <div>
            <h2 style="margin:0">QR Code</h2>
            <div class="muted small">Escaneie pelo WhatsApp</div>
          </div>
        </div>

        <div class="qr-area" id="qrArea">
          <% if (botState.qr) { %>
            <img src="<%= botState.qr %>" alt="QR Code" id="qrImg" />
          <% } else if (botState.status === 'connected') { %>
            <div class="qr-placeholder success">
              <div class="qr-icon">✅</div>
              <p><strong>Conectado!</strong></p>
              <p class="muted small" style="margin-top:.3rem"><%= botState.user?.id?.split(':')[0] %></p>
            </div>
          <% } else { %>
            <div class="qr-placeholder">
              <div class="qr-icon">📱</div>
              <p class="muted">Clique em <strong>Gerar QR</strong></p>
              <p class="muted small mt-1">WhatsApp → Aparelhos conectados → Conectar</p>
            </div>
          <% } %>
        </div>

        <div id="qrTimer" style="display:none;text-align:center;margin-top:.75rem">
          <div class="muted small">⏱️ QR expira em: <strong id="qrCountdown" style="color:var(--neon-cyan)">--</strong></div>
          <div style="width:100%;height:4px;background:var(--bg-2);border-radius:2px;margin-top:.5rem;overflow:hidden">
            <div id="qrProgress" style="height:100%;background:var(--gradient-3);border-radius:2px;transition:width 1s linear;width:100%"></div>
          </div>
        </div>

        <div class="button-row" style="margin-top:1rem">
          <button class="btn btn-primary" id="btnQr" onclick="startQR()" <%= botState.status === 'connected' ? 'disabled' : '' %>>
            📱 Gerar QR Code
          </button>
        </div>
        <div class="muted small mt-1" style="text-align:center">Gera um novo QR a cada conexão</div>
      </div>

      <!-- PAIR CODE CARD -->
      <div class="card" id="pairCard">
        <div style="display:flex;align-items:center;gap:.75rem;margin-bottom:1rem">
          <div style="width:48px;height:48px;border-radius:12px;background:linear-gradient(135deg,rgba(0,255,157,.2),rgba(0,240,255,.2));display:flex;align-items:center;justify-content:center;font-size:1.5rem;border:1px solid var(--border)">🔐</div>
          <div>
            <h2 style="margin:0">Pair Code</h2>
            <div class="muted small">Vincular com código numérico</div>
          </div>
        </div>

        <div class="form-group">
          <label>Número do WhatsApp (com DDI)</label>
          <input type="tel" id="pairNumber" placeholder="Ex: 244945280380" value="<%= owner.number %>" />
          <small class="muted">DDI + DDD + número. Sem + ou espaços. Este é o número que receberá o código.</small>
        </div>

        <div class="pair-area" id="pairArea">
          <% if (botState.pairingCode) { %>
            <div style="text-align:center">
              <div class="muted small" style="margin-bottom:.5rem">SEU PAIR CODE:</div>
              <div class="pair-code" id="pairCodeDisplay"><%= botState.pairingCode %></div>
              <div style="margin-top:.75rem">
                <button class="btn btn-sm btn-primary" onclick="copyPairCode()">📋 Copiar Código</button>
              </div>
              <div class="muted small" style="margin-top:.5rem">⏱️ Expira em ~3 minutos</div>
              <div class="alert alert-info mt-2" style="text-align:left;font-size:.82rem;padding:.6rem .8rem">
                <strong>Passos:</strong><br>
                1. Abra WhatsApp no telemóvel<br>
                2. Menu ⋮ → Aparelhos conectados → Vincular<br>
                3. Digite o código acima
              </div>
            </div>
          <% } else { %>
            <div class="qr-placeholder">
              <div class="qr-icon">🔐</div>
              <p class="muted">Clique em <strong>Gerar Pair Code</strong></p>
              <p class="muted small mt-1">O código será enviado para o WhatsApp do número</p>
            </div>
          <% } %>
        </div>

        <div class="button-row" style="margin-top:1rem">
          <button class="btn btn-success" id="btnPair" onclick="startPair()" <%= botState.status === 'connected' ? 'disabled' : '' %>>
            🔐 Gerar Pair Code
          </button>
        </div>
        <div class="muted small mt-1" style="text-align:center">O código aparece aqui e pode ser notificado via WhatsApp</div>
      </div>
    </div>

    <!-- LOG DE CONEXÃO -->
    <div class="card">
      <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:.85rem">
        <div style="display:flex;align-items:center;gap:.75rem">
          <div style="width:32px;height:32px;border-radius:8px;background:rgba(0,255,157,.1);display:flex;align-items:center;justify-content:center;font-size:1rem;border:1px solid rgba(0,255,157,.2)">📡</div>
          <h2 style="margin:0">Log de Conexão</h2>
        </div>
        <button class="btn btn-sm btn-ghost" onclick="clearLog()">🗑️ Limpar</button>
      </div>
      <div class="console" id="connLog" style="height:220px">
        <% (botState.recentLogs || []).slice(-20).forEach(l => { %>
          <div class="console-line log-<%= l.level %>">
            <span class="console-time">[<%= new Date(l.time).toLocaleTimeString('pt-BR') %>]</span>
            <%= l.message %>
          </div>
        <% }) %>
        <% if (!botState.recentLogs?.length) { %>
          <div class="console-line muted">Aguardando ação...</div>
        <% } %>
      </div>
    </div>

  </main>
</div>

<script>
  const socket = io({ reconnection: true });
  const statusText = document.getElementById('botStatusText');
  const statusDot = document.querySelector('#botStatusBadge .status-dot');
  const qrArea = document.getElementById('qrArea');
  const pairArea = document.getElementById('pairArea');
  const connLog = document.getElementById('connLog');
  const connectedBanner = document.getElementById('connectedBanner');
  let currentPairCode = '';
  let qrTimerInterval = null;

  function addLog(level, msg) {
    if (!connLog) return;
    const t = new Date().toLocaleTimeString('pt-BR');
    const d = document.createElement('div');
    d.className = `console-line log-${level}`;
    const safe = String(msg).replace(/</g,'&lt;').replace(/>/g,'&gt;');
    d.innerHTML = `<span class="console-time">[${t}]</span> ${safe}`;
    connLog.appendChild(d);
    connLog.scrollTop = connLog.scrollHeight;
    if (connLog.children.length > 80) connLog.removeChild(connLog.firstChild);
  }

  function clearLog() {
    if (connLog) connLog.innerHTML = '<div class="console-line muted">Log limpo.</div>';
  }

  function copyPairCode() {
    if (currentPairCode) {
      navigator.clipboard?.writeText(currentPairCode);
      toast('📋 Código copiado!', 'success', 2000);
    }
  }

  function startQrCountdown() {
    clearInterval(qrTimerInterval);
    const timerEl = document.getElementById('qrTimer');
    const countdownEl = document.getElementById('qrCountdown');
    const progressEl = document.getElementById('qrProgress');
    if (!timerEl) return;
    timerEl.style.display = 'block';
    let seconds = 60;
    countdownEl.textContent = seconds + 's';
    progressEl.style.width = '100%';
    qrTimerInterval = setInterval(() => {
      seconds--;
      if (seconds <= 0) {
        clearInterval(qrTimerInterval);
        timerEl.style.display = 'none';
        qrArea.innerHTML = '<div class="qr-placeholder"><div class="qr-icon">⏱️</div><p class="muted">QR expirado. Gere um novo.</p></div>';
        addLog('warn', '⏱️ QR Code expirado');
        const btnQr = document.getElementById('btnQr');
        if (btnQr) { btnQr.disabled = false; btnQr.textContent = '📱 Gerar QR Code'; }
        return;
      }
      countdownEl.textContent = seconds + 's';
      progressEl.style.width = (seconds / 60 * 100) + '%';
    }, 1000);
  }

  socket.on('bot:status', (data) => {
    if (!data.status) return;
    const s = data.status;
    if (statusText) statusText.textContent = s;
    if (statusDot) statusDot.className = 'status-dot status-' + s;

    // CONNECTED
    if (s === 'connected') {
      clearInterval(qrTimerInterval);
      if (connectedBanner) connectedBanner.style.display = 'block';
      document.getElementById('connInstructions').style.display = 'none';
      ['btnQr','btnPair'].forEach(id => { const el = document.getElementById(id); if(el) el.disabled = true; });

      const userInfo = data.user?.id?.split(':')[0] || '';
      qrArea.innerHTML = `<div class="qr-placeholder success"><div class="qr-icon">✅</div><p><strong>Conectado!</strong></p><p class="muted small">+${userInfo}</p></div>`;
      pairArea.innerHTML = `<div class="qr-placeholder success"><div class="qr-icon">✅</div><p><strong>Ativo!</strong></p></div>`;
      document.getElementById('qrTimer')?.style && (document.getElementById('qrTimer').style.display = 'none');

      const infoEl = document.getElementById('connectedInfo');
      if (infoEl && userInfo) infoEl.textContent = 'Número: +' + userInfo;

      toast('✅ Bot conectado ao WhatsApp!', 'success', 5000);
      addLog('success', `✅ Conectado como: +${userInfo}`);
    }

    // QR CODE
    if (s === 'qr' && data.qr) {
      qrArea.innerHTML = `<img src="${data.qr}" alt="QR Code" style="max-width:280px;width:100%;border-radius:16px;background:white;padding:12px;box-shadow:0 0 40px rgba(0,240,255,.3);animation:qrGlow 2s ease-in-out infinite" />`;
      startQrCountdown();
      addLog('success', '📱 QR Code gerado — escaneie agora!');
      toast('📱 QR Code pronto — escaneie!', 'success');
      const btnQr = document.getElementById('btnQr');
      if (btnQr) { btnQr.disabled = false; btnQr.textContent = '📱 Gerar QR Code'; }
    }

    // PAIR CODE
    if (s === 'pairing' && data.pairingCode) {
      currentPairCode = data.pairingCode;
      pairArea.innerHTML = `
        <div style="text-align:center;width:100%">
          <div class="muted small" style="margin-bottom:.5rem;letter-spacing:2px">SEU PAIR CODE</div>
          <div class="pair-code" id="pairCodeDisplay">${data.pairingCode}</div>
          <div style="margin-top:1rem;display:flex;gap:.5rem;justify-content:center;flex-wrap:wrap">
            <button class="btn btn-sm btn-primary" onclick="copyPairCode()">📋 Copiar Código</button>
          </div>
          <div class="alert alert-info mt-2" style="text-align:left;font-size:.82rem;padding:.6rem .8rem;max-width:400px;margin-left:auto;margin-right:auto">
            <strong>Como usar:</strong><br>
            1. Abra WhatsApp no telemóvel<br>
            2. Menu ⋮ → Aparelhos conectados → Vincular<br>
            3. Digite: <code style="font-size:1.1em;color:var(--neon-green);letter-spacing:2px">${data.pairingCode}</code><br>
            4. Aguarde a confirmação
          </div>
          <div class="muted small" style="margin-top:.5rem">⏱️ Expira em ~3 minutos</div>
        </div>`;
      addLog('success', `🔐 Pair Code gerado: ${data.pairingCode}`);
      toast(`🔐 Pair Code: ${data.pairingCode}`, 'success', 10000);
      const btnPair = document.getElementById('btnPair');
      if (btnPair) { btnPair.disabled = false; btnPair.textContent = '🔐 Gerar Pair Code'; }
    }

    // DISCONNECTED
    if (s === 'disconnected') {
      clearInterval(qrTimerInterval);
      addLog('warn', '⚠️ Desconectado');
      ['btnQr','btnPair'].forEach(id => { const el = document.getElementById(id); if(el) el.disabled = false; });
      const btnQr = document.getElementById('btnQr');
      if (btnQr) btnQr.textContent = '📱 Gerar QR Code';
      const btnPair = document.getElementById('btnPair');
      if (btnPair) btnPair.textContent = '🔐 Gerar Pair Code';
    }

    // CONNECTING
    if (s === 'connecting') {
      qrArea.innerHTML = `<div class="qr-placeholder"><div class="spinner"></div><p class="muted mt-1">Conectando ao WhatsApp...</p></div>`;
      addLog('info', '🔄 Conectando ao WhatsApp...');
    }
  });

  socket.on('bot:log', (data) => addLog(data.level || 'info', data.message));
  socket.on('bot:error', (data) => { addLog('error', '❌ ' + data.message); toast(data.message, 'error'); });

  async function startQR() {
    const btn = document.getElementById('btnQr');
    btn.disabled = true;
    btn.textContent = '⏳ Gerando...';
    qrArea.innerHTML = `<div class="qr-placeholder"><div class="spinner"></div><p class="muted mt-1">Gerando QR Code...</p></div>`;
    addLog('info', '🔄 Iniciando com QR Code...');
    try {
      await fetch('/api/bot/start', { method: 'POST', headers: {'Content-Type':'application/json'}, body: JSON.stringify({ mode: 'qr' }) });
    } catch(e) {
      toast(e.message, 'error');
      btn.disabled = false;
      btn.textContent = '📱 Gerar QR Code';
    }
  }

  async function startPair() {
    const num = document.getElementById('pairNumber')?.value?.replace(/\D/g, '');
    if (!num || num.length < 10) { toast('❌ Número inválido (mín. 10 dígitos com DDI)', 'error'); return; }
    const btn = document.getElementById('btnPair');
    btn.disabled = true;
    btn.textContent = '⏳ Gerando...';
    pairArea.innerHTML = `<div class="qr-placeholder"><div class="spinner"></div><p class="muted mt-1">Gerando Pair Code para ${num}...</p></div>`;
    addLog('info', `🔐 Solicitando pair code para ${num}...`);
    try {
      const res = await fetch('/api/bot/start', { method: 'POST', headers: {'Content-Type':'application/json'}, body: JSON.stringify({ mode: 'pair', phoneNumber: num }) });
      const data = await res.json();
      if (!res.ok) throw new Error(data.error || 'Falha');
      addLog('info', `📱 Pair code solicitado. Aguarde o código aparecer...`);
    } catch(e) {
      toast(e.message, 'error');
      btn.disabled = false;
      btn.textContent = '🔐 Gerar Pair Code';
    }
  }

  async function disconnectBot() {
    if (!confirm('Desconectar o bot do WhatsApp? A sessão será mantida.')) return;
    try {
      await fetch('/api/bot/logout', { method: 'POST' });
      toast('🔌 Bot desconectado.', 'warn');
      location.reload();
    } catch(e) { toast(e.message, 'error'); }
  }

  async function resetSession() {
    if (!confirm('Resetar a sessão completamente? O bot terá que ser conectado novamente do zero.')) return;
    try {
      await fetch('/api/bot/reset', { method: 'POST' });
      toast('♻️ Sessão resetada.', 'warn');
      setTimeout(() => location.reload(), 1500);
    } catch(e) { toast(e.message, 'error'); }
  }
</script>
<%- include('../partials/footer') %>
