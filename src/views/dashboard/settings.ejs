<%- include('../partials/head') %>
<div class="app-shell">
  <%- include('../partials/sidebar') %>
  <main class="main">
    <header class="page-header">
      <div>
        <h1>⚙️ Configurações</h1>
        <p class="muted">Personalize comportamentos globais do bot</p>
      </div>
    </header>

    <!-- MULTI-PREFIXO -->
    <div class="card" style="border-color:var(--neon-cyan)">
      <h2>🔤 Prefixos de Comando (multi-prefixo)</h2>
      <p class="muted">Configure quantos prefixos quiser, separados por <strong>espaço</strong> ou <strong>vírgula</strong>. O bot vai responder a qualquer um deles!</p>
      <form id="prefixForm">
        <div class="form-group">
          <label>Prefixos ativos</label>
          <input type="text" id="prefixesInput" value="<%= (prefixes || ['!']).join(' ') %>" placeholder="! . / # $ % &" />
          <small class="muted">Exemplos: <code>!</code> | <code>! .</code> | <code>! . / #</code> | <code>.bot ,bot </code></small>
        </div>
        <div class="form-group">
          <label>📌 Prefixo principal (usado nas respostas e menu)</label>
          <input type="text" value="<%= (prefixes || ['!'])[0] %>" disabled />
          <small class="muted">Sempre o primeiro da lista acima</small>
        </div>
        <button type="submit" class="btn btn-primary">💾 Salvar Prefixos</button>
        <button type="button" class="btn btn-ghost" onclick="resetPrefix()">🔄 Resetar para !</button>
      </form>
      <div class="alert alert-info" style="margin-top:1rem">
        <span>💡</span>
        <span>Com multi-prefixo, usuários podem usar <code>!menu</code>, <code>.menu</code>, <code>/menu</code> e todos funcionam!</span>
      </div>
    </div>

    <!-- BOAS-VINDAS -->
    <div class="card">
      <h2>👋 Boas-vindas / Despedidas</h2>
      <form id="welcomeForm">
        <div class="form-group form-check">
          <label><input type="checkbox" id="welcomeEnabled" <%= settings.welcome_enabled !== false ? 'checked' : '' %> /> Mensagem de boas-vindas ATIVA</label>
        </div>
        <div class="form-group">
          <label>Mensagem ao ENTRAR (use @user e @grupo)</label>
          <textarea id="welcomeMessage" rows="5"><%= settings.welcome_message || '╭━〔 🌙 *BEM-VINDO* 〕━╮\n│ 👋 Olá @user!\n│ 🎉 Você entrou em *@grupo*\n│ 🤖 Powered by ' + bot.name + '\n╰━━━━━━━━━━━━━━━━━╯' %></textarea>
        </div>
        <div class="form-group">
          <label>Mensagem ao SAIR</label>
          <textarea id="goodbyeMessage" rows="3"><%= settings.goodbye_message || '👋 @user saiu de *@grupo*. Até mais!' %></textarea>
        </div>
        <button type="submit" class="btn btn-primary">💾 Salvar</button>
      </form>
    </div>

    <!-- INFO -->
    <div class="card">
      <h2>🤖 Info do Bot</h2>
      <div class="form-grid">
        <div class="form-group">
          <label>Nome do Bot</label>
          <input type="text" value="<%= bot.name %>" disabled />
          <small class="muted">Variável de ambiente</small>
        </div>
        <div class="form-group">
          <label>Número do Bot</label>
          <input type="text" value="<%= bot.number %>" disabled />
        </div>
        <div class="form-group">
          <label>Dono</label>
          <input type="text" value="<%= owner.name %>" disabled />
        </div>
        <div class="form-group">
          <label>Número do Dono</label>
          <input type="text" value="<%= owner.number %>" disabled />
        </div>
      </div>
    </div>

    <div class="card">
      <h2>🎨 Marca d'água em Stickers</h2>
      <p class="muted">As figurinhas geradas pelo bot contêm automaticamente:</p>
      <ul style="margin: 1rem 0 0 1.5rem; line-height: 2;">
        <li>📛 <strong>Pack:</strong> <%= bot.name %> • Dono: <%= owner.name %></li>
        <li>👤 <strong>Author:</strong> Nome do usuário | Nome do grupo</li>
      </ul>
    </div>
  </main>
</div>
<script>
  // Multi-prefixo
  document.getElementById('prefixForm').onsubmit = async (e) => {
    e.preventDefault();
    const raw = document.getElementById('prefixesInput').value.trim();
    if (!raw) { toast('Coloque pelo menos 1 prefixo', 'error'); return; }
    const arr = raw.split(/[\s,]+/).filter(Boolean);
    try {
      const r = await fetch('/api/prefixes', {
        method: 'POST', headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ prefixes: arr }),
      });
      if (r.ok) {
        toast('Prefixos salvos: ' + arr.join(' '), 'success');
        setTimeout(() => location.reload(), 1200);
      } else toast('Erro ao salvar', 'error');
    } catch (err) { toast(err.message, 'error'); }
  };

  async function resetPrefix() {
    if (!confirm('Resetar para apenas !?')) return;
    document.getElementById('prefixesInput').value = '!';
    document.getElementById('prefixForm').dispatchEvent(new Event('submit'));
  }

  // Welcome
  document.getElementById('welcomeForm').onsubmit = async (e) => {
    e.preventDefault();
    try {
      const r = await fetch('/api/settings', {
        method: 'POST', headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          welcome_enabled: document.getElementById('welcomeEnabled').checked,
          welcome_message: document.getElementById('welcomeMessage').value,
          goodbye_message: document.getElementById('goodbyeMessage').value,
        }),
      });
      if (r.ok) toast('Configurações salvas!', 'success');
      else toast('Erro ao salvar', 'error');
    } catch (err) { toast(err.message, 'error'); }
  };
</script>
<%- include('../partials/footer') %>
