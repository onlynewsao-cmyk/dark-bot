<%- include('../partials/head') %>
<div class="app-shell">
  <%- include('../partials/sidebar') %>
  <main class="main">
    <header class="page-header">
      <div>
        <h1>💻 Console Live</h1>
        <p class="muted">Logs do bot em tempo real via Socket.IO</p>
      </div>
      <div class="bot-status">
        <span class="status-dot status-<%= botState.status %>"></span>
        <span id="botStatusText"><%= botState.status %></span>
      </div>
    </header>

    <div class="card">
      <div class="button-row mb-2">
        <button class="btn btn-sm btn-ghost" onclick="document.getElementById('liveConsole').innerHTML=''">🗑️ Limpar</button>
        <button class="btn btn-sm btn-ghost" id="autoScrollBtn">📜 Auto-scroll: ON</button>
        <span class="muted">Os logs aparecem em tempo real conforme o bot opera</span>
      </div>
      <div class="console" id="liveConsole" style="height:600px;font-size:0.9rem">
        <div class="console-line log-info">
          <span class="console-time">[--:--:--]</span> 🔗 Conectando ao stream de logs...
        </div>
      </div>
    </div>
  </main>
</div>
<script>
  const socket = io({ reconnection: true });
  const liveConsole = document.getElementById('liveConsole');
  let autoScroll = true;

  document.getElementById('autoScrollBtn').onclick = function() {
    autoScroll = !autoScroll;
    this.textContent = '📜 Auto-scroll: ' + (autoScroll ? 'ON' : 'OFF');
  };

  function log(level, msg) {
    const time = new Date().toLocaleTimeString('pt-BR');
    const line = document.createElement('div');
    line.className = `console-line log-${level}`;
    line.innerHTML = `<span class="console-time">[${time}]</span> ${msg}`;
    liveConsole.appendChild(line);
    if (autoScroll) liveConsole.scrollTop = liveConsole.scrollHeight;
    if (liveConsole.children.length > 500) liveConsole.removeChild(liveConsole.firstChild);
  }

  socket.on('connect', () => log('success', '✅ Socket conectado'));
  socket.on('disconnect', () => log('warn', '⚠️ Socket desconectado'));
  socket.on('bot:status', (d) => log('info', `📡 Status: ${d.status}${d.pairingCode ? ' (code: ' + d.pairingCode + ')' : ''}`));
  socket.on('bot:log', (d) => log(d.level || 'info', d.message));
  socket.on('bot:error', (d) => log('error', '❌ ' + d.message));
</script>
<%- include('../partials/footer') %>
