<%- include('partials/head') %>
<style>
  .landing { min-height:100vh; display:flex; align-items:center; justify-content:center; padding:2rem; text-align:center; }
  .landing-card {
    max-width:650px; background:var(--bg-card); backdrop-filter:blur(30px);
    border:1px solid var(--border); border-radius:24px; padding:3rem 2rem;
    box-shadow:0 30px 80px rgba(0,0,0,.6);
  }
  .landing-logo { margin-bottom:1rem; animation:logoPulse 3s ease-in-out infinite; }
  .landing-title {
    font-family:'Orbitron',sans-serif; font-size:2.5rem; font-weight:900;
    letter-spacing:4px; background:var(--gradient-1); -webkit-background-clip:text;
    -webkit-text-fill-color:transparent; background-clip:text; margin-bottom:.5rem; text-transform:uppercase;
  }
  .landing-subtitle { color:var(--text-muted); font-size:.9rem; letter-spacing:3px; text-transform:uppercase; margin-bottom:1.5rem; }
  .landing-tagline { color:var(--neon-cyan); font-size:1rem; margin-bottom:2rem; font-style:italic; }
  .landing-buttons { display:flex; gap:1rem; justify-content:center; flex-wrap:wrap; margin-bottom:2rem; }
  .landing-features { display:grid; grid-template-columns:repeat(auto-fit,minmax(140px,1fr)); gap:.85rem; margin-top:2rem; }
  .feature {
    padding:1rem; border:1px solid var(--border); border-radius:12px;
    background:rgba(0,0,0,.3); transition:all .3s;
  }
  .feature:hover { border-color:var(--neon-purple); transform:translateY(-3px); box-shadow:0 8px 20px rgba(177,74,237,.2); }
  .feature-icon { font-size:2rem; margin-bottom:.5rem; }
  .feature-text { font-size:.8rem; color:var(--text-muted); font-weight:600; }
  .owner-info { margin-top:2rem; padding-top:1.5rem; border-top:1px solid var(--border); color:var(--text-muted); font-size:.85rem; }
  .owner-name { color:var(--neon-yellow); font-weight:700; font-family:'Orbitron',sans-serif; }
  .stats-bar { display:flex; justify-content:center; gap:2rem; margin:1.5rem 0; flex-wrap:wrap; }
  .stat-mini { text-align:center; }
  .stat-mini-val { font-family:'Orbitron',sans-serif; font-size:1.5rem; font-weight:900; background:var(--gradient-1); -webkit-background-clip:text; -webkit-text-fill-color:transparent; }
  .stat-mini-label { font-size:.7rem; color:var(--text-muted); text-transform:uppercase; letter-spacing:1px; }
</style>

<div class="landing">
  <div class="landing-card">
    <div class="landing-logo"><img src="/img/logo.jpg" alt="Logo" style="width:120px;height:120px;border-radius:50%;object-fit:cover;box-shadow:0 0 40px rgba(177,74,237,0.6)" /></div>
    <h1 class="landing-title"><%= bot.name %></h1>
    <div class="landing-subtitle">⌁ ᴛʜᴇ ᴅᴀʀᴋ sɪᴅᴇ ᴏꜰ ᴀᴜᴛᴏᴍᴀᴛɪᴏɴ ⌁</div>
    <p class="landing-tagline">"In darkness, we automate. In silence, we dominate."</p>

    <div class="stats-bar">
      <div class="stat-mini"><div class="stat-mini-val">161+</div><div class="stat-mini-label">Comandos</div></div>
      <div class="stat-mini"><div class="stat-mini-val">22</div><div class="stat-mini-label">Formatos VPN</div></div>
      <div class="stat-mini"><div class="stat-mini-val">24/7</div><div class="stat-mini-label">Online</div></div>
    </div>

    <div class="landing-buttons">
      <a href="/login" class="btn btn-primary" style="padding:.85rem 2rem">🔐 Entrar</a>
      <a href="/register" class="btn btn-ghost" style="padding:.85rem 2rem">📝 Criar Conta</a>
    </div>

    <div class="landing-features">
      <div class="feature"><div class="feature-icon">🤖</div><div class="feature-text">Bot WhatsApp</div></div>
      <div class="feature"><div class="feature-icon">🧠</div><div class="feature-text">IA Integrada</div></div>
      <div class="feature"><div class="feature-icon">🔓</div><div class="feature-text">VPN Decrypter</div></div>
      <div class="feature"><div class="feature-icon">🎮</div><div class="feature-text">Jogos & Economia</div></div>
      <div class="feature"><div class="feature-icon">📥</div><div class="feature-text">Downloads</div></div>
      <div class="feature"><div class="feature-icon">💕</div><div class="feature-text">Interações + GIF</div></div>
      <div class="feature"><div class="feature-icon">🎨</div><div class="feature-text">Sticker Maker</div></div>
      <div class="feature"><div class="feature-icon">⭐</div><div class="feature-text">Premium</div></div>
    </div>

    <div class="owner-info">
      👑 Powered by <span class="owner-name"><%= owner.name %></span><br>
      📞 wa.me/<%= owner.number %> · 🤖 +<%= bot.number %>
    </div>
  </div>
</div>
<%- include('partials/footer') %>
