<%- include('partials/head') %>

<style>
  .landing { min-height: 100vh; display: flex; align-items: center; justify-content: center; padding: 2rem; }
  .landing-card {
    max-width: 680px; width: 100%;
    background: rgba(8, 8, 26, 0.88);
    backdrop-filter: blur(40px);
    border: 1px solid rgba(177,74,237,0.25);
    border-radius: 28px;
    padding: 3.5rem 2.5rem;
    box-shadow: 0 40px 100px rgba(0,0,0,0.7), 0 0 60px rgba(177,74,237,0.08);
    text-align: center;
  }
  .landing-logo {
    margin-bottom: 1.5rem;
    animation: logoPulse 3s ease-in-out infinite;
  }
  .landing-logo img {
    width: 130px; height: 130px;
    border-radius: 50%;
    object-fit: cover;
    box-shadow: 0 0 50px rgba(177,74,237,0.7), 0 0 100px rgba(0,240,255,0.2);
  }
  .landing-title {
    font-family: 'Orbitron', sans-serif;
    font-size: 2.8rem;
    font-weight: 900;
    letter-spacing: 5px;
    background: var(--gradient-1);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    margin-bottom: .4rem;
    text-transform: uppercase;
  }
  .landing-subtitle {
    color: var(--text-muted);
    font-size: .82rem;
    letter-spacing: 4px;
    text-transform: uppercase;
    margin-bottom: 1.25rem;
  }
  .landing-quote {
    color: var(--neon-cyan);
    font-size: .95rem;
    font-style: italic;
    margin-bottom: 2rem;
    padding: .75rem 1.5rem;
    border-left: 2px solid var(--neon-cyan);
    text-align: left;
    background: rgba(0,240,255,.05);
    border-radius: 0 8px 8px 0;
  }
  .stats-bar {
    display: flex;
    justify-content: center;
    gap: 2.5rem;
    margin: 1.75rem 0;
    flex-wrap: wrap;
    padding: 1.25rem;
    background: rgba(0,0,0,.25);
    border-radius: 16px;
    border: 1px solid var(--border);
  }
  .stat-mini { text-align: center; }
  .stat-mini-val {
    font-family: 'Orbitron', sans-serif;
    font-size: 1.8rem;
    font-weight: 900;
    background: var(--gradient-1);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }
  .stat-mini-label {
    font-size: .68rem;
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 1.5px;
    margin-top: .2rem;
  }
  .landing-buttons {
    display: flex;
    gap: 1rem;
    justify-content: center;
    flex-wrap: wrap;
    margin: 1.75rem 0;
  }
  .features-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(130px, 1fr));
    gap: .75rem;
    margin-top: 2rem;
  }
  .feature {
    padding: .9rem;
    border: 1px solid var(--border);
    border-radius: 12px;
    background: rgba(0,0,0,.3);
    transition: all .3s;
    cursor: default;
  }
  .feature:hover {
    border-color: var(--neon-purple);
    transform: translateY(-3px);
    background: rgba(177,74,237,.08);
  }
  .feature-icon { font-size: 1.8rem; margin-bottom: .4rem; }
  .feature-text { font-size: .75rem; color: var(--text-muted); font-weight: 700; letter-spacing: .5px; }
  .owner-strip {
    margin-top: 2rem;
    padding-top: 1.25rem;
    border-top: 1px solid var(--border);
    color: var(--text-muted);
    font-size: .82rem;
  }
  .owner-name {
    color: var(--neon-yellow);
    font-weight: 900;
    font-family: 'Orbitron', sans-serif;
    font-size: .8rem;
  }
</style>

<div class="landing">
  <div class="landing-card">

    <div class="landing-logo">
      <img src="/img/logo.jpg" alt="<%= bot.name %>" />
    </div>

    <h1 class="landing-title"><%= bot.name %></h1>
    <p class="landing-subtitle">⌁ ᴛʜᴇ ᴅᴀʀᴋ sɪᴅᴇ ᴏꜰ ᴀᴜᴛᴏᴍᴀᴛɪᴏɴ ⌁</p>

    <div class="landing-quote">
      "In darkness, we automate. In silence, we dominate."
    </div>

    <div class="stats-bar">
      <div class="stat-mini">
        <div class="stat-mini-val">161+</div>
        <div class="stat-mini-label">Comandos</div>
      </div>
      <div class="stat-mini">
        <div class="stat-mini-val">22</div>
        <div class="stat-mini-label">Formatos VPN</div>
      </div>
      <div class="stat-mini">
        <div class="stat-mini-val">24/7</div>
        <div class="stat-mini-label">Online</div>
      </div>
      <div class="stat-mini">
        <div class="stat-mini-val">v3</div>
        <div class="stat-mini-label">Dashboard</div>
      </div>
    </div>

    <div class="landing-buttons">
      <a href="/login" class="btn btn-primary" style="padding:.85rem 2.25rem;font-size:1rem">🔐 Entrar</a>
      <a href="/register" class="btn btn-ghost" style="padding:.85rem 2.25rem;font-size:1rem">📝 Criar Conta</a>
    </div>

    <div class="features-grid">
      <div class="feature"><div class="feature-icon">🤖</div><div class="feature-text">Bot WhatsApp</div></div>
      <div class="feature"><div class="feature-icon">🧠</div><div class="feature-text">IA Integrada</div></div>
      <div class="feature"><div class="feature-icon">🔓</div><div class="feature-text">VPN Decrypter</div></div>
      <div class="feature"><div class="feature-icon">🎮</div><div class="feature-text">Jogos & Eco.</div></div>
      <div class="feature"><div class="feature-icon">📥</div><div class="feature-text">Downloads</div></div>
      <div class="feature"><div class="feature-icon">💕</div><div class="feature-text">Interações</div></div>
      <div class="feature"><div class="feature-icon">🎨</div><div class="feature-text">Stickers</div></div>
      <div class="feature"><div class="feature-icon">⭐</div><div class="feature-text">Premium</div></div>
      <div class="feature"><div class="feature-icon">👁️</div><div class="feature-text">Anti-Delete</div></div>
      <div class="feature"><div class="feature-icon">🛡️</div><div class="feature-text">Anti-Spam</div></div>
    </div>

    <div class="owner-strip">
      <div>Desenvolvido por <span class="owner-name"><%= owner.name %></span></div>
      <div style="margin-top:.4rem">
        <a href="https://wa.me/<%= owner.number %>" target="_blank" style="color:var(--neon-green);font-size:.8rem">📞 +<%= owner.number %></a>
      </div>
    </div>

  </div>
</div>

<%- include('partials/footer') %>
