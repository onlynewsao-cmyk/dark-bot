<aside class="sidebar">
  <div class="sidebar-brand">
    <div class="brand-logo">🤖</div>
    <div>
      <div class="brand-name"><%= bot.name %></div>
      <div class="brand-owner">⚡ by <%= owner.name %></div>
    </div>
  </div>

  <nav class="sidebar-nav">
    <div class="sidebar-section">Geral</div>
    <a href="/dashboard" class="<%= currentPath === '/dashboard' ? 'active' : '' %>">
      <span class="icon">📊</span> Dashboard
    </a>
    <a href="/dashboard/profile" class="<%= currentPath.startsWith('/dashboard/profile') ? 'active' : '' %>">
      <span class="icon">👤</span> Meu Perfil
    </a>
    <a href="/dashboard/decrypter" class="<%= currentPath.startsWith('/dashboard/decrypter') ? 'active' : '' %>">
      <span class="icon">🔓</span> VPN Decrypter
    </a>
    <a href="/dashboard/subscribe" class="<%= currentPath.startsWith('/dashboard/subscribe') ? 'active' : '' %>">
      <span class="icon">⭐</span> Assinar Premium
    </a>

    <% if (user.role === 'owner') { %>
      <div class="sidebar-section">🎛️ Controle</div>
      <a href="/dashboard/control" class="<%= currentPath.startsWith('/dashboard/control') ? 'active' : '' %>">
        <span class="icon">🎛️</span> Painel de Controle
      </a>
      <a href="/dashboard/connect" class="<%= currentPath.startsWith('/dashboard/connect') ? 'active' : '' %>">
        <span class="icon">🔌</span> Conectar Bot
      </a>
      <a href="/dashboard/console" class="<%= currentPath.startsWith('/dashboard/console') ? 'active' : '' %>">
        <span class="icon">💻</span> Console Live
      </a>
      <a href="/dashboard/broadcast" class="<%= currentPath.startsWith('/dashboard/broadcast') ? 'active' : '' %>">
        <span class="icon">📢</span> Broadcast
      </a>
      <a href="/dashboard/schedule" class="<%= currentPath.startsWith('/dashboard/schedule') ? 'active' : '' %>">
        <span class="icon">📅</span> Agendamentos
      </a>

      <div class="sidebar-section">⚡ Gestão</div>
      <a href="/dashboard/commands" class="<%= currentPath.startsWith('/dashboard/commands') ? 'active' : '' %>">
        <span class="icon">⚡</span> Comandos
      </a>
      <a href="/dashboard/media" class="<%= currentPath.startsWith('/dashboard/media') ? 'active' : '' %>">
        <span class="icon">🖼️</span> Mídias
      </a>
      <a href="/dashboard/ia" class="<%= currentPath.startsWith('/dashboard/ia') ? 'active' : '' %>">
        <span class="icon">🧠</span> IA
      </a>
      <a href="/dashboard/settings" class="<%= currentPath.startsWith('/dashboard/settings') ? 'active' : '' %>">
        <span class="icon">⚙️</span> Configurações
      </a>
      <a href="/dashboard/groups" class="<%= currentPath.startsWith('/dashboard/groups') ? 'active' : '' %>">
        <span class="icon">👥</span> Grupos
      </a>

      <div class="sidebar-section">💼 Negócio</div>
      <a href="/dashboard/users" class="<%= currentPath.startsWith('/dashboard/users') ? 'active' : '' %>">
        <span class="icon">👥</span> Usuários
      </a>
      <a href="/dashboard/payments" class="<%= currentPath.startsWith('/dashboard/payments') ? 'active' : '' %>">
        <span class="icon">💳</span> Pagamentos
      </a>
      <a href="/dashboard/stats" class="<%= currentPath.startsWith('/dashboard/stats') ? 'active' : '' %>">
        <span class="icon">📈</span> Estatísticas
      </a>
      <a href="/dashboard/backup" class="<%= currentPath.startsWith('/dashboard/backup') ? 'active' : '' %>">
        <span class="icon">💾</span> Backup
      </a>
    <% } %>
  </nav>

  <div class="sidebar-footer">
    <div class="user-card">
      <div class="user-avatar"><%= (user.name || user.username).charAt(0).toUpperCase() %></div>
      <div style="flex:1;min-width:0">
        <div class="user-name"><%= user.name || user.username %></div>
        <div class="user-role role-<%= user.role %>">
          <% if (user.role === 'owner') { %>👑 Dono<% } else if (user.role === 'premium') { %>⭐ Premium<% } else { %>🆓 Free<% } %>
        </div>
      </div>
    </div>
    <a href="/logout" class="btn btn-ghost btn-block">🚪 Sair</a>
  </div>
</aside>
